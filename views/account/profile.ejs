<!-- PROFILE SETTINGS PAGE -->
<div class="min-h-screen bg-gray-50">
  <div class="page-hero">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl mb-1">⚙️ Profile Settings</h1>
      <p class="text-white/70">Manage your account details</p>
    </div>
  </div>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-6">

    <% if (updateSuccess) { %>
    <div class="bg-green-50 border-l-4 border-green-500 rounded-xl p-4 flex items-center gap-3">
      <i class="fas fa-check-circle text-green-500"></i>
      <p class="text-green-700 font-medium text-sm"><%= updateSuccess %></p>
    </div>
    <% } %>
    <% if (updateError) { %>
    <div class="bg-red-50 border-l-4 border-rescue-red rounded-xl p-4 flex items-center gap-3">
      <i class="fas fa-exclamation-circle text-rescue-red"></i>
      <p class="text-red-700 font-medium text-sm"><%= updateError %></p>
    </div>
    <% } %>

    <!-- Profile Form -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center gap-4 mb-6 pb-5 border-b border-gray-100">
        <div class="w-16 h-16 bg-rescue-red rounded-2xl flex items-center justify-center font-black text-3xl text-white">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div>
          <p class="font-display font-bold text-lg text-gray-800"><%= user.name %></p>
          <p class="text-gray-500 text-sm"><%= user.email %></p>
          <span class="text-xs bg-rescue-red/10 text-rescue-red px-2 py-0.5 rounded-full font-semibold capitalize"><%= user.role %></span>
        </div>
      </div>

      <h3 class="font-display font-bold text-base text-gray-800 mb-4">Personal Information</h3>
      <form action="/account/profile" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name</label>
          <input type="text" name="name" value="<%= user.name %>" required class="form-input">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">School</label>
            <input type="text" name="school" value="<%= user.school || '' %>" placeholder="Your school name" class="form-input">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Level</label>
            <select name="grade_level" class="form-input">
              <option value="">-- Select Level --</option>
              <% ['IGCSE Year 10','IGCSE Year 11','AP Year 11','AP Year 12','SABIS Grade 9','SABIS Grade 10','SABIS Grade 11','SABIS Grade 12','University','Other'].forEach(l => { %>
              <option value="<%= l %>" <%= user.grade_level === l ? 'selected' : '' %>><%= l %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Country</label>
          <select name="country" class="form-input">
            <option value="">-- Select Country --</option>
            <% ['United Arab Emirates','Saudi Arabia','United Kingdom','United States','Egypt','Qatar','Kuwait','Jordan','Lebanon','Australia','Canada','Other'].forEach(c => { %>
            <option value="<%= c %>" <%= user.country === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="bg-rescue-red text-white px-6 py-3 rounded-xl font-bold hover:bg-rescue-red-dark transition-all">
          Save Changes
        </button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h3 class="font-display font-bold text-base text-gray-800 mb-4">🔒 Change Password</h3>
      <form action="/account/change-password" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Current Password</label>
          <input type="password" name="current_password" required class="form-input">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">New Password</label>
            <input type="password" name="new_password" required minlength="8" class="form-input">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirm New</label>
            <input type="password" name="confirm_password" required class="form-input">
          </div>
        </div>
        <button type="submit" class="bg-gray-800 text-white px-6 py-3 rounded-xl font-bold hover:bg-gray-700 transition-all">
          Update Password
        </button>
      </form>
    </div>

    <!-- Account Info -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
      <h3 class="font-display font-bold text-base text-gray-800 mb-4">Account Information</h3>
      <div class="space-y-3 text-sm text-gray-600">
        <div class="flex justify-between"><span>Email</span><span class="font-semibold"><%= user.email %></span></div>
        <div class="flex justify-between"><span>Member Since</span><span class="font-semibold"><%= new Date(user.created_at).toLocaleDateString() %></span></div>
        <div class="flex justify-between"><span>Last Login</span><span class="font-semibold"><%= user.last_login ? new Date(user.last_login).toLocaleDateString() : 'Now' %></span></div>
      </div>
    </div>
  </div>
</div>
