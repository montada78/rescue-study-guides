<!-- Account Dashboard -->
<div class="min-h-screen bg-gray-50">
  <!-- Account Header -->
  <div class="bg-rescue-dark text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-rescue-red rounded-2xl flex items-center justify-center font-black text-2xl">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <h1 class="font-display font-bold text-xl">Welcome back, <%= user.name.split(' ')[0] %>! 👋</h1>
            <p class="text-gray-400 text-sm"><%= user.email %> • <%= user.grade_level || 'Student' %></p>
          </div>
        </div>
        <a href="/shop" class="btn-rescue hidden md:flex">
          <i class="fas fa-shopping-bag mr-2"></i>Browse More Guides
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center">
        <div class="text-3xl font-black text-rescue-red mb-1"><%= stats.totalDownloads %></div>
        <p class="text-gray-500 text-xs font-medium">My Guides</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center">
        <div class="text-3xl font-black text-blue-600 mb-1"><%= stats.totalOrders %></div>
        <p class="text-gray-500 text-xs font-medium">Orders</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center">
        <div class="text-3xl font-black text-green-600 mb-1">$<%= stats.totalSpent.toFixed(2) %></div>
        <p class="text-gray-500 text-xs font-medium">Total Spent</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center">
        <div class="text-3xl font-black text-yellow-600 mb-1"><%= stats.wishlistCount %></div>
        <p class="text-gray-500 text-xs font-medium">Wishlist</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- My Downloads -->
      <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="font-display font-bold text-lg text-gray-800">📥 My Study Guides</h2>
          <a href="/account/downloads" class="text-rescue-red text-sm font-semibold hover:underline">View All →</a>
        </div>
        
        <% if (downloads.length === 0) { %>
        <div class="text-center py-10">
          <div class="text-5xl mb-3">📚</div>
          <p class="text-gray-500 text-sm">No guides yet — let's fix that!</p>
          <a href="/shop" class="btn-rescue mt-4 text-sm">Shop Guides</a>
        </div>
        <% } else { %>
        <div class="space-y-3">
          <% downloads.forEach(dl => { %>
          <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-rescue-red/30 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-rescue-red/10 flex items-center justify-center text-2xl flex-shrink-0">
              <%= dl.subject === 'Mathematics' ? '🔢' : dl.subject === 'Biology' ? '🧬' : dl.subject === 'Chemistry' ? '⚗️' : dl.subject === 'Physics' ? '⚡' : '📚' %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm text-gray-800 truncate"><%= dl.title %></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= dl.level %> • <%= dl.curriculum %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= dl.download_count %>/<%= dl.max_downloads %> downloads used</p>
            </div>
            <a href="/downloads/file/<%= dl.download_token %>" class="flex-shrink-0 bg-rescue-red text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-rescue-red-dark transition-colors flex items-center gap-1">
              <i class="fas fa-download"></i>
              <span class="hidden sm:inline">Download</span>
            </a>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <!-- Quick Links -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h3 class="font-display font-bold text-base text-gray-800 mb-4">Quick Links</h3>
          <div class="space-y-2">
            <a href="/account/downloads" class="flex items-center gap-3 p-3 rounded-xl hover:bg-red-50 hover:text-rescue-red transition-colors text-gray-600 group">
              <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center group-hover:bg-rescue-red group-hover:text-white transition-colors">
                <i class="fas fa-download text-xs text-rescue-red group-hover:text-white"></i>
              </div>
              <span class="text-sm font-medium">My Downloads</span>
            </a>
            <a href="/account/orders" class="flex items-center gap-3 p-3 rounded-xl hover:bg-blue-50 hover:text-blue-600 transition-colors text-gray-600">
              <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center"><i class="fas fa-receipt text-xs text-blue-500"></i></div>
              <span class="text-sm font-medium">Order History</span>
            </a>
            <a href="/account/wishlist" class="flex items-center gap-3 p-3 rounded-xl hover:bg-pink-50 hover:text-pink-600 transition-colors text-gray-600">
              <div class="w-8 h-8 bg-pink-100 rounded-lg flex items-center justify-center"><i class="fas fa-heart text-xs text-pink-500"></i></div>
              <span class="text-sm font-medium">Wishlist (<%= stats.wishlistCount %>)</span>
            </a>
            <a href="/account/profile" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 transition-colors text-gray-600">
              <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center"><i class="fas fa-cog text-xs text-gray-500"></i></div>
              <span class="text-sm font-medium">Profile Settings</span>
            </a>
          </div>
        </div>

        <!-- Wishlist preview -->
        <% if (wishlist.length > 0) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-display font-bold text-base text-gray-800">❤️ Wishlist</h3>
            <a href="/account/wishlist" class="text-rescue-red text-xs hover:underline">View All</a>
          </div>
          <div class="space-y-2">
            <% wishlist.slice(0, 3).forEach(item => { %>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center text-lg flex-shrink-0">📚</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-semibold text-gray-700 truncate"><%= item.title %></p>
                <p class="text-rescue-red font-bold text-xs">$<%= item.price.toFixed(2) %></p>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
