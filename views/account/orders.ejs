<!-- ORDERS PAGE -->
<div class="min-h-screen bg-gray-50">
  <div class="page-hero">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl mb-1">🧾 My Orders</h1>
      <p class="text-white/70">Your purchase history</p>
    </div>
  </div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <% if (orders.length === 0) { %>
    <div class="text-center py-20 bg-white rounded-3xl shadow-sm border border-gray-100">
      <div class="text-7xl mb-4">🧾</div>
      <h3 class="font-display font-bold text-xl text-gray-700 mb-2">No orders yet!</h3>
      <a href="/shop" class="btn-rescue mt-4">Shop Now</a>
    </div>
    <% } else { %>
    <div class="space-y-5">
      <% orders.forEach(order => { %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="font-display font-bold text-gray-800"><%= order.order_number %></p>
            <p class="text-xs text-gray-500 mt-0.5"><%= new Date(order.created_at).toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) %></p>
          </div>
          <div class="text-right">
            <span class="px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700"><%= order.status.toUpperCase() %></span>
            <p class="font-black text-rescue-red text-xl mt-1">$<%= order.total_amount.toFixed(2) %></p>
          </div>
        </div>
        <div class="space-y-2 border-t border-gray-100 pt-4">
          <% order.items.forEach(item => { %>
          <div class="flex items-center gap-3 text-sm">
            <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center text-lg">📚</div>
            <span class="text-gray-700 flex-1"><%= item.title %></span>
            <span class="font-semibold text-gray-800">$<%= item.price.toFixed(2) %></span>
          </div>
          <% }) %>
        </div>
        <div class="mt-4 pt-3 border-t border-gray-50">
          <a href="/account/downloads" class="text-rescue-red text-sm font-semibold hover:underline">
            <i class="fas fa-download mr-1"></i>Go to Downloads
          </a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
