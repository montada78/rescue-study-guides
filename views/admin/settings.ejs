<!-- Admin Payment Settings -->
<div class="flex min-h-screen bg-gray-100">
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0">
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center gap-3">
        <svg width="36" height="36" viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/><path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/><path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/><path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/><path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/><circle cx="50" cy="50" r="18" fill="white"/><text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946">RSG</text></svg>
        <div><p class="font-display font-black text-sm text-rescue-red">RESCUE</p><p class="text-xs text-gray-400">Admin Panel</p></div>
      </div>
    </div>
    <nav class="p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tachometer-alt w-4 text-rescue-red"></i> Dashboard</a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-book w-4 text-rescue-red"></i> Products</a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-plus-circle w-4 text-green-400"></i> Add Guide</a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-receipt w-4 text-rescue-red"></i> Orders</a>
      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-users w-4 text-rescue-red"></i> Users</a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tags w-4 text-rescue-red"></i> Categories</a>
      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium bg-rescue-red text-white"><i class="fas fa-cog w-4"></i> Settings</a>
      <div class="pt-4 border-t border-gray-700 mt-4">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-400 hover:bg-gray-700"><i class="fas fa-external-link-alt w-4"></i> View Site</a>
        <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-400 hover:bg-red-900/30"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
      </div>
    </nav>
  </aside>

  <main class="flex-1 overflow-auto">
    <div class="bg-white shadow-sm px-8 py-4">
      <h1 class="font-display font-bold text-xl text-gray-800">⚙️ Payment & Settings</h1>
    </div>

    <div class="p-8 max-w-3xl space-y-6">

      <% if (saved) { %>
      <div class="bg-green-50 border-l-4 border-green-500 rounded-xl p-4 flex items-center gap-3">
        <i class="fas fa-check-circle text-green-500"></i>
        <p class="text-green-700 font-semibold text-sm">✅ Settings saved! Restart the server for changes to take effect.</p>
      </div>
      <% } %>

      <form action="/admin/settings" method="POST" class="space-y-6">

        <!-- STRIPE -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-credit-card text-purple-600"></i>
            </div>
            <div>
              <h3 class="font-bold text-gray-800">Stripe — Credit & Debit Cards</h3>
              <p class="text-xs text-gray-500">Get keys at <a href="https://dashboard.stripe.com/apikeys" target="_blank" class="text-purple-600 underline">dashboard.stripe.com/apikeys</a></p>
            </div>
            <div class="ml-auto">
              <span class="px-2 py-1 rounded-full text-xs font-bold <%= settings.STRIPE_SECRET_KEY && !settings.STRIPE_SECRET_KEY.includes('YOUR_') ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= settings.STRIPE_SECRET_KEY && !settings.STRIPE_SECRET_KEY.includes('YOUR_') ? '✅ Active' : '⚠️ Not configured' %>
              </span>
            </div>
          </div>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Publishable Key (pk_live_... or pk_test_...)</label>
              <input type="text" name="STRIPE_PUBLISHABLE_KEY" value="<%= settings.STRIPE_PUBLISHABLE_KEY || '' %>"
                placeholder="pk_live_xxxxxxxxxxxxxxxxxxxx" class="form-input font-mono text-sm">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Secret Key (sk_live_... or sk_test_...)</label>
              <input type="password" name="STRIPE_SECRET_KEY" value="<%= settings.STRIPE_SECRET_KEY || '' %>"
                placeholder="sk_live_xxxxxxxxxxxxxxxxxxxx" class="form-input font-mono text-sm">
            </div>
          </div>
        </div>

        <!-- PAYPAL -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
              <i class="fab fa-paypal text-blue-600 text-lg"></i>
            </div>
            <div>
              <h3 class="font-bold text-gray-800">PayPal</h3>
              <p class="text-xs text-gray-500">Get keys at <a href="https://developer.paypal.com/dashboard" target="_blank" class="text-blue-600 underline">developer.paypal.com</a></p>
            </div>
            <div class="ml-auto">
              <span class="px-2 py-1 rounded-full text-xs font-bold <%= settings.PAYPAL_CLIENT_ID && !settings.PAYPAL_CLIENT_ID.includes('YOUR_') ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= settings.PAYPAL_CLIENT_ID && !settings.PAYPAL_CLIENT_ID.includes('YOUR_') ? '✅ Active' : '⚠️ Not configured' %>
              </span>
            </div>
          </div>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Client ID</label>
              <input type="text" name="PAYPAL_CLIENT_ID" value="<%= settings.PAYPAL_CLIENT_ID || '' %>"
                placeholder="Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" class="form-input font-mono text-sm">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Client Secret</label>
              <input type="password" name="PAYPAL_CLIENT_SECRET" value="<%= settings.PAYPAL_CLIENT_SECRET || '' %>"
                placeholder="Exxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" class="form-input font-mono text-sm">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Mode</label>
              <select name="PAYPAL_MODE" class="form-input">
                <option value="sandbox" <%= (settings.PAYPAL_MODE || 'sandbox') === 'sandbox' ? 'selected' : '' %>>🧪 Sandbox (Testing)</option>
                <option value="live" <%= settings.PAYPAL_MODE === 'live' ? 'selected' : '' %>>🚀 Live (Production)</option>
              </select>
            </div>
          </div>
        </div>

        <!-- SITE SETTINGS -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-rescue-red/10 rounded-xl flex items-center justify-center">
              <i class="fas fa-globe text-rescue-red"></i>
            </div>
            <h3 class="font-bold text-gray-800">Site Settings</h3>
          </div>
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Site URL</label>
              <input type="url" name="APP_URL" value="<%= settings.APP_URL || '' %>"
                placeholder="https://www.rescuestudyguides.com" class="form-input">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">Admin Email</label>
              <input type="email" name="ADMIN_EMAIL" value="<%= settings.ADMIN_EMAIL || '' %>" class="form-input">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1.5">New Admin Password <span class="text-gray-400 font-normal">(leave blank to keep current)</span></label>
              <input type="password" name="ADMIN_PASSWORD" placeholder="New password..." class="form-input">
            </div>
          </div>
        </div>

        <button type="submit" class="w-full bg-rescue-red text-white py-4 rounded-xl font-black text-base hover:bg-rescue-red-dark transition-all shadow-md">
          <i class="fas fa-save mr-2"></i>Save All Settings
        </button>
        <p class="text-center text-xs text-gray-400">Settings are saved to the .env file. The server restarts automatically.</p>
      </form>
    </div>
  </main>
</div>
