<!-- Admin Settings -->
<div class="flex min-h-screen bg-gray-100">
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0">
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center gap-3">
        <svg width="36" height="36" viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/><path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/><path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/><path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/><path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/><circle cx="50" cy="50" r="18" fill="white"/><text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946">RSG</text></svg>
        <div><p class="font-display font-black text-sm text-rescue-red">RESCUE</p><p class="text-xs text-gray-400">Admin Panel</p></div>
      </div>
    </div>
    <nav class="p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tachometer-alt w-4 text-rescue-red"></i> Dashboard</a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-book w-4 text-rescue-red"></i> Products</a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-plus-circle w-4 text-green-400"></i> Add Guide</a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-receipt w-4 text-rescue-red"></i> Orders</a>
      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-users w-4 text-rescue-red"></i> Users</a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tags w-4 text-rescue-red"></i> Categories</a>
      <a href="/admin/coupons" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-ticket-alt w-4 text-rescue-red"></i> Coupons</a>
      <a href="/admin/access-codes" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-key w-4 text-rescue-red"></i> Access Codes</a>      <a href="/admin/file-recovery" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10"><i class="fas fa-file-medical w-4"></i> File Recovery</a>

      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium bg-rescue-red text-white"><i class="fas fa-cog w-4"></i> Settings</a>
      <div class="pt-4 border-t border-gray-700 mt-4">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-400 hover:bg-gray-700"><i class="fas fa-external-link-alt w-4"></i> View Site</a>
        <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-400 hover:bg-red-900/30"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
      </div>
    </nav>
  </aside>

  <main class="flex-1 overflow-auto">
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <h1 class="font-display font-bold text-xl text-gray-800">&#9881;&#65039; Site Settings (36 Options)</h1>
    </div>

    <div class="p-8 max-w-3xl space-y-6">

      <% if (locals.saved) { %>
      <div class="bg-green-50 border-l-4 border-green-500 rounded-xl p-4 flex items-center gap-3">
        <i class="fas fa-check-circle text-green-500"></i>
        <p class="text-green-700 font-semibold text-sm">&#9989; Settings saved! Restart the server for changes to take effect.</p>
      </div>
      <% } %>

      <form action="/admin/settings" method="POST" class="space-y-6">

        <!-- 1. STRIPE -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center"><i class="fas fa-credit-card text-purple-600"></i></div>
            <div>
              <h3 class="font-bold text-gray-800">&#x1F4B3; Stripe — Credit &amp; Debit Cards</h3>
              <p class="text-xs text-gray-500">Get keys at <a href="https://dashboard.stripe.com/apikeys" target="_blank" class="text-purple-600 underline">dashboard.stripe.com</a></p>
            </div>
            <% var stripeOk = settings.STRIPE_SECRET_KEY && !settings.STRIPE_SECRET_KEY.includes('demo'); %>
            <span class="ml-auto px-2 py-1 rounded-full text-xs font-bold <%= stripeOk ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= stripeOk ? '&#9989; Active' : '&#9888;&#65039; Not configured' %>
            </span>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Publishable Key</label>
              <input type="text" name="STRIPE_PUBLISHABLE_KEY" value="<%= settings.STRIPE_PUBLISHABLE_KEY || '' %>" placeholder="pk_live_..." class="form-input font-mono text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Secret Key</label>
              <input type="password" name="STRIPE_SECRET_KEY" value="<%= settings.STRIPE_SECRET_KEY || '' %>" placeholder="sk_live_..." class="form-input font-mono text-sm"></div>
          </div>
        </div>

        <!-- 2. PAYPAL -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center"><i class="fab fa-paypal text-blue-600 text-lg"></i></div>
            <div>
              <h3 class="font-bold text-gray-800">&#x1F17F;&#65039; PayPal</h3>
              <p class="text-xs text-gray-500">Get keys at <a href="https://developer.paypal.com/dashboard" target="_blank" class="text-blue-600 underline">developer.paypal.com</a></p>
            </div>
            <% var ppOk = settings.PAYPAL_CLIENT_ID && !settings.PAYPAL_CLIENT_ID.includes('YOUR_'); %>
            <span class="ml-auto px-2 py-1 rounded-full text-xs font-bold <%= ppOk ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= ppOk ? '&#9989; Active' : '&#9888;&#65039; Not configured' %>
            </span>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Client ID</label>
              <input type="text" name="PAYPAL_CLIENT_ID" value="<%= settings.PAYPAL_CLIENT_ID || '' %>" placeholder="AxxxxxxxxxxxxxxxxxxxxxxxxXxx" class="form-input font-mono text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Client Secret</label>
              <input type="password" name="PAYPAL_CLIENT_SECRET" value="<%= settings.PAYPAL_CLIENT_SECRET || '' %>" placeholder="Exxxxxxxxxxxxxxxxxxxxxxxxxx" class="form-input font-mono text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Mode</label>
              <select name="PAYPAL_MODE" class="form-input">
                <% var ppMode = settings.PAYPAL_MODE || 'sandbox'; %>
                <option value="sandbox" <%= ppMode === 'sandbox' ? 'selected' : '' %>>&#x1F9EA; Sandbox (Testing)</option>
                <option value="live" <%= ppMode === 'live' ? 'selected' : '' %>>&#x1F680; Live (Production)</option>
              </select></div>
          </div>
        </div>

        <!-- 3. SITE IDENTITY -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center"><i class="fas fa-globe text-rescue-red"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F310; Site Identity</h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Site Name</label>
              <input type="text" name="APP_NAME" value="<%= settings.APP_NAME || 'Rescue Study Guides' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Site URL</label>
              <input type="url" name="APP_URL" value="<%= settings.APP_URL || '' %>" placeholder="https://www.examrescueguides.com" class="form-input text-sm"></div>
            <div class="md:col-span-2"><label class="block text-xs font-semibold text-gray-600 mb-1">Site Tagline</label>
              <input type="text" name="SITE_TAGLINE" value="<%= settings.SITE_TAGLINE || 'From I Dont Get It to I Ace It!' %>" class="form-input text-sm" placeholder="Your site slogan"></div>
          </div>
        </div>

        <!-- 4. PROMO BANNER -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-yellow-100 rounded-xl flex items-center justify-center"><i class="fas fa-bullhorn text-yellow-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4E3; Promo Banner</h3>
          </div>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label class="text-sm font-semibold text-gray-700">Show Banner</label>
              <% var bannerOn = settings.PROMO_BANNER_ENABLED; %>
              <select name="PROMO_BANNER_ENABLED" class="form-input w-32 text-sm">
                <option value="true" <%= bannerOn === 'true' ? 'selected' : '' %>>&#9989; Yes</option>
                <option value="false" <%= bannerOn === 'false' ? 'selected' : '' %>>&#10060; No</option>
              </select>
            </div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Banner Text</label>
              <input type="text" name="PROMO_BANNER_TEXT" value="<%= settings.PROMO_BANNER_TEXT || 'EXAM SEASON SALE - 30% OFF all guides' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Promo Code to Show</label>
              <input type="text" name="PROMO_BANNER_CODE" value="<%= settings.PROMO_BANNER_CODE || 'RESCUE30' %>" class="form-input text-sm font-mono" placeholder="RESCUE30"></div>
          </div>
        </div>

        <!-- 5. EMAIL & CONTACT -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center"><i class="fas fa-envelope text-green-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4E7; Email &amp; Contact</h3>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Contact Email (receives contact form messages)</label>
              <input type="email" name="CONTACT_EMAIL" value="<%= settings.CONTACT_EMAIL || 'kanayatichemistry@gmail.com' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Gmail App Password <span class="text-gray-400 font-normal">(for sending emails)</span></label>
              <input type="password" name="CONTACT_EMAIL_PASS" value="<%= settings.CONTACT_EMAIL_PASS || '' %>" placeholder="16-digit app password" class="form-input text-sm font-mono">
              <p class="text-xs text-gray-400 mt-1">Get at myaccount.google.com &rarr; Security &rarr; App Passwords</p></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Support WhatsApp Number</label>
              <input type="text" name="SUPPORT_WHATSAPP" value="<%= settings.SUPPORT_WHATSAPP || '' %>" placeholder="+971501234567" class="form-input text-sm"></div>
          </div>
        </div>

        <!-- 6. SOCIAL MEDIA -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-pink-100 rounded-xl flex items-center justify-center"><i class="fas fa-share-alt text-pink-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4F1; Social Media Links</h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-instagram text-pink-500 mr-1"></i>Instagram URL</label>
              <input type="url" name="INSTAGRAM_URL" value="<%= settings.INSTAGRAM_URL || '' %>" placeholder="https://instagram.com/yourpage" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-tiktok mr-1"></i>TikTok URL</label>
              <input type="url" name="TIKTOK_URL" value="<%= settings.TIKTOK_URL || '' %>" placeholder="https://tiktok.com/@yourpage" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-youtube text-red-500 mr-1"></i>YouTube URL</label>
              <input type="url" name="YOUTUBE_URL" value="<%= settings.YOUTUBE_URL || '' %>" placeholder="https://youtube.com/@yourchannel" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-facebook text-blue-500 mr-1"></i>Facebook URL</label>
              <input type="url" name="FACEBOOK_URL" value="<%= settings.FACEBOOK_URL || '' %>" placeholder="https://facebook.com/yourpage" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-twitter text-sky-400 mr-1"></i>Twitter / X URL</label>
              <input type="url" name="TWITTER_URL" value="<%= settings.TWITTER_URL || '' %>" placeholder="https://x.com/yourhandle" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1"><i class="fab fa-linkedin text-blue-700 mr-1"></i>LinkedIn URL</label>
              <input type="url" name="LINKEDIN_URL" value="<%= settings.LINKEDIN_URL || '' %>" placeholder="https://linkedin.com/company/yourpage" class="form-input text-sm"></div>
          </div>
        </div>

        <!-- 7. CURRENCY & DOWNLOADS -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center"><i class="fas fa-dollar-sign text-emerald-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4B0; Currency &amp; Downloads</h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Currency Code</label>
              <% var cur = settings.CURRENCY || 'USD'; %>
              <select name="CURRENCY" class="form-input text-sm">
                <option value="USD" <%= cur === 'USD' ? 'selected' : '' %>>USD – US Dollar</option>
                <option value="AED" <%= cur === 'AED' ? 'selected' : '' %>>AED – UAE Dirham</option>
                <option value="GBP" <%= cur === 'GBP' ? 'selected' : '' %>>GBP – British Pound</option>
                <option value="EUR" <%= cur === 'EUR' ? 'selected' : '' %>>EUR – Euro</option>
                <option value="SAR" <%= cur === 'SAR' ? 'selected' : '' %>>SAR – Saudi Riyal</option>
              </select></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Currency Symbol</label>
              <input type="text" name="CURRENCY_SYMBOL" value="<%= settings.CURRENCY_SYMBOL || '$' %>" class="form-input text-sm w-24" placeholder="$"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Default Max Downloads per Purchase</label>
              <input type="number" name="DEFAULT_DOWNLOAD_LIMIT" value="<%= settings.DEFAULT_DOWNLOAD_LIMIT || '5' %>" min="1" max="999" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Free Guide Download Limit</label>
              <input type="number" name="FREE_DOWNLOAD_LIMIT" value="<%= settings.FREE_DOWNLOAD_LIMIT || '3' %>" min="1" class="form-input text-sm"></div>
          </div>
        </div>

        <!-- 8. SEO & ANALYTICS -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center"><i class="fas fa-chart-line text-orange-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4CA; SEO &amp; Analytics</h3>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Google Analytics ID</label>
              <input type="text" name="GOOGLE_ANALYTICS_ID" value="<%= settings.GOOGLE_ANALYTICS_ID || '' %>" placeholder="G-XXXXXXXXXX or UA-XXXXXXXX" class="form-input text-sm font-mono"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Meta Description</label>
              <textarea name="META_DESCRIPTION" rows="2" class="form-input text-sm resize-none" placeholder="High-quality colorful revision guides for IGCSE, AP, SABIS..."><%= settings.META_DESCRIPTION || '' %></textarea></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Meta Keywords</label>
              <input type="text" name="META_KEYWORDS" value="<%= settings.META_KEYWORDS || 'igcse, ap chemistry, study guides, revision' %>" class="form-input text-sm"></div>
            <div class="grid md:grid-cols-2 gap-4">
              <div><label class="block text-xs font-semibold text-gray-600 mb-1">Facebook Pixel ID</label>
                <input type="text" name="FACEBOOK_PIXEL_ID" value="<%= settings.FACEBOOK_PIXEL_ID || '' %>" placeholder="123456789012345" class="form-input text-sm font-mono"></div>
              <div><label class="block text-xs font-semibold text-gray-600 mb-1">Tawk.to Property ID (live chat)</label>
                <input type="text" name="TAWK_PROPERTY_ID" value="<%= settings.TAWK_PROPERTY_ID || '' %>" placeholder="xxxxxxxx/default" class="form-input text-sm font-mono"></div>
            </div>
          </div>
        </div>

        <!-- 9. ADMIN & SECURITY -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center"><i class="fas fa-shield-alt text-gray-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F510; Admin &amp; Security</h3>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Admin Email</label>
              <input type="email" name="ADMIN_EMAIL" value="<%= settings.ADMIN_EMAIL || '' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">New Admin Password <span class="text-gray-400 font-normal">(leave blank to keep current)</span></label>
              <input type="password" name="ADMIN_PASSWORD" placeholder="New password..." class="form-input text-sm"></div>
            <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
              <div>
                <label class="text-sm font-semibold text-gray-700">Allow New Registrations</label>
                <p class="text-xs text-gray-400">Let new students create accounts</p>
              </div>
              <% var regOn = settings.ALLOW_REGISTRATION || 'true'; %>
              <select name="ALLOW_REGISTRATION" class="form-input w-24 text-sm">
                <option value="true" <%= regOn === 'true' ? 'selected' : '' %>>&#9989; Yes</option>
                <option value="false" <%= regOn === 'false' ? 'selected' : '' %>>&#10060; No</option>
              </select>
            </div>
            <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
              <div>
                <label class="text-sm font-semibold text-gray-700">Maintenance Mode</label>
                <p class="text-xs text-gray-400">Show "Under Maintenance" to visitors</p>
              </div>
              <% var maintOn = settings.MAINTENANCE_MODE || 'false'; %>
              <select name="MAINTENANCE_MODE" class="form-input w-24 text-sm">
                <option value="false" <%= maintOn === 'false' ? 'selected' : '' %>>&#x1F7E2; Off</option>
                <option value="true" <%= maintOn === 'true' ? 'selected' : '' %>>&#x1F534; On</option>
              </select>
            </div>
            <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
              <div>
                <label class="text-sm font-semibold text-gray-700">Require Email Verification</label>
                <p class="text-xs text-gray-400">Before students can purchase</p>
              </div>
              <% var verifyOn = settings.REQUIRE_EMAIL_VERIFY || 'false'; %>
              <select name="REQUIRE_EMAIL_VERIFY" class="form-input w-24 text-sm">
                <option value="false" <%= verifyOn === 'false' ? 'selected' : '' %>>&#10060; Off</option>
                <option value="true" <%= verifyOn === 'true' ? 'selected' : '' %>>&#9989; On</option>
              </select>
            </div>
          </div>
        </div>

        <!-- 10. BRANDING & APPEARANCE -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center"><i class="fas fa-palette text-indigo-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F3A8; Branding &amp; Appearance</h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Logo URL (hosted image link)</label>
              <input type="url" name="SITE_LOGO_URL" value="<%= settings.SITE_LOGO_URL || '' %>" placeholder="https://example.com/logo.png" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Favicon URL</label>
              <input type="url" name="SITE_FAVICON_URL" value="<%= settings.SITE_FAVICON_URL || '' %>" placeholder="https://example.com/favicon.ico" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Primary Brand Color</label>
              <div class="flex gap-2 items-center">
                <input type="color" name="SITE_PRIMARY_COLOR" value="<%= settings.SITE_PRIMARY_COLOR || '#E63946' %>" class="h-10 w-16 rounded-lg border border-gray-200 cursor-pointer">
                <span class="text-xs text-gray-400"><%= settings.SITE_PRIMARY_COLOR || '#E63946' %></span>
              </div>
            </div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Footer Text</label>
              <input type="text" name="FOOTER_TEXT" value="<%= settings.FOOTER_TEXT || 'Rescue Study Guides' %>" class="form-input text-sm"></div>
            <div class="md:col-span-2"><label class="block text-xs font-semibold text-gray-600 mb-1">Copyright Text</label>
              <input type="text" name="COPYRIGHT_TEXT" value="<%= settings.COPYRIGHT_TEXT || '2026 Rescue Study Guides. All rights reserved.' %>" class="form-input text-sm"></div>
          </div>
        </div>

        <!-- 11. HOMEPAGE CUSTOMIZATION -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-yellow-100 rounded-xl flex items-center justify-center"><i class="fas fa-home text-yellow-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F3E0; Homepage Customization</h3>
          </div>
          <div class="space-y-3">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Hero Title</label>
              <input type="text" name="HOMEPAGE_HERO_TITLE" value="<%= settings.HOMEPAGE_HERO_TITLE || 'From I Dont Get It to I Ace It!' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Hero Subtitle</label>
              <input type="text" name="HOMEPAGE_HERO_SUBTITLE" value="<%= settings.HOMEPAGE_HERO_SUBTITLE || 'High-quality colorful revision guides for IGCSE, AP, SABIS and more' %>" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Featured Section Title</label>
              <input type="text" name="FEATURED_SECTION_TITLE" value="<%= settings.FEATURED_SECTION_TITLE || 'Featured Rescue Guides' %>" class="form-input text-sm"></div>
            <div class="grid md:grid-cols-3 gap-3">
              <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
                <label class="text-xs font-semibold text-gray-700">How It Works</label>
                <% var howOn = settings.HOW_IT_WORKS_ENABLED || 'true'; %>
                <select name="HOW_IT_WORKS_ENABLED" class="form-input w-20 text-xs ml-1">
                  <option value="true" <%= howOn === 'true' ? 'selected' : '' %>>Show</option>
                  <option value="false" <%= howOn === 'false' ? 'selected' : '' %>>Hide</option>
                </select>
              </div>
              <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
                <label class="text-xs font-semibold text-gray-700">Reviews</label>
                <% var revOn = settings.REVIEWS_ENABLED || 'true'; %>
                <select name="REVIEWS_ENABLED" class="form-input w-20 text-xs ml-1">
                  <option value="true" <%= revOn === 'true' ? 'selected' : '' %>>Show</option>
                  <option value="false" <%= revOn === 'false' ? 'selected' : '' %>>Hide</option>
                </select>
              </div>
              <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
                <label class="text-xs font-semibold text-gray-700">Wishlist</label>
                <% var wishOn = settings.WISHLIST_ENABLED || 'true'; %>
                <select name="WISHLIST_ENABLED" class="form-input w-20 text-xs ml-1">
                  <option value="true" <%= wishOn === 'true' ? 'selected' : '' %>>On</option>
                  <option value="false" <%= wishOn === 'false' ? 'selected' : '' %>>Off</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- 12. SMTP EMAIL SERVER -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-cyan-100 rounded-xl flex items-center justify-center"><i class="fas fa-server text-cyan-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4EC; SMTP Email Server <span class="text-xs text-gray-400 font-normal ml-2">(optional — alternative to Gmail)</span></h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">SMTP Host</label>
              <input type="text" name="SMTP_HOST" value="<%= settings.SMTP_HOST || '' %>" placeholder="smtp.gmail.com or smtp.sendgrid.net" class="form-input text-sm font-mono"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">SMTP Port</label>
              <input type="number" name="SMTP_PORT" value="<%= settings.SMTP_PORT || '587' %>" placeholder="587" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">SMTP Username</label>
              <input type="text" name="SMTP_USER" value="<%= settings.SMTP_USER || '' %>" placeholder="your@email.com" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">SMTP Password</label>
              <input type="password" name="SMTP_PASS" value="<%= settings.SMTP_PASS || '' %>" placeholder="password" class="form-input text-sm"></div>
            <div class="md:col-span-2"><label class="block text-xs font-semibold text-gray-600 mb-1">From Name</label>
              <input type="text" name="SMTP_FROM_NAME" value="<%= settings.SMTP_FROM_NAME || 'Rescue Study Guides' %>" class="form-input text-sm"></div>
          </div>
        </div>

        <!-- 13. TAX / VAT -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center"><i class="fas fa-percentage text-red-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F9FE; Tax / VAT Settings</h3>
          </div>
          <div class="grid md:grid-cols-3 gap-4">
            <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
              <label class="text-sm font-semibold text-gray-700">Enable Tax</label>
              <% var taxOn = settings.ENABLE_TAX || 'false'; %>
              <select name="ENABLE_TAX" class="form-input w-20 text-sm ml-2">
                <option value="false" <%= taxOn === 'false' ? 'selected' : '' %>>Off</option>
                <option value="true" <%= taxOn === 'true' ? 'selected' : '' %>>On</option>
              </select>
            </div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Tax Rate (%)</label>
              <input type="number" name="TAX_RATE" value="<%= settings.TAX_RATE || '0' %>" min="0" max="100" step="0.1" class="form-input text-sm" placeholder="e.g. 5"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Tax Label</label>
              <input type="text" name="TAX_LABEL" value="<%= settings.TAX_LABEL || 'VAT' %>" class="form-input text-sm" placeholder="VAT, GST, Tax..."></div>
          </div>
        </div>

        <!-- 14. ADVANCED PURCHASE SETTINGS -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"><i class="fas fa-sliders-h text-violet-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x2699;&#65039; Advanced Purchase Settings</h3>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Max Items in Cart</label>
              <input type="number" name="MAX_CART_ITEMS" value="<%= settings.MAX_CART_ITEMS || '20' %>" min="1" class="form-input text-sm"></div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Free Trial Access (days after signup, 0=off)</label>
              <input type="number" name="FREE_TRIAL_DAYS" value="<%= settings.FREE_TRIAL_DAYS || '0' %>" min="0" class="form-input text-sm"></div>
            <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3">
              <div>
                <label class="text-sm font-semibold text-gray-700">Watermark PDF Downloads</label>
                <p class="text-xs text-gray-400">Add student email to downloaded PDFs</p>
              </div>
              <% var wmOn = settings.WATERMARK_DOWNLOADS || 'false'; %>
              <select name="WATERMARK_DOWNLOADS" class="form-input w-20 text-sm ml-2">
                <option value="false" <%= wmOn === 'false' ? 'selected' : '' %>>Off</option>
                <option value="true" <%= wmOn === 'true' ? 'selected' : '' %>>On</option>
              </select>
            </div>
            <div><label class="block text-xs font-semibold text-gray-600 mb-1">Order Notification Email</label>
              <input type="email" name="ORDER_NOTIFICATION_EMAIL" value="<%= settings.ORDER_NOTIFICATION_EMAIL || settings.ADMIN_EMAIL || '' %>" placeholder="get notified on each order" class="form-input text-sm">
              <p class="text-xs text-gray-400 mt-1">Email sent on every new order</p></div>
          </div>
        </div>

        <!-- 15. CUSTOM CODE INJECTION -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center"><i class="fas fa-code text-gray-600"></i></div>
            <h3 class="font-bold text-gray-800">&#x1F4BB; Custom Code Injection</h3>
          </div>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">Custom &lt;head&gt; Code <span class="text-gray-400 font-normal">(Google Tag Manager, custom CSS, meta tags)</span></label>
              <textarea name="CUSTOM_HEAD_CODE" rows="3" class="form-input text-sm font-mono resize-none text-xs"
                placeholder="<!-- paste your head code here -->"><%= settings.CUSTOM_HEAD_CODE || '' %></textarea>
              <p class="text-xs text-gray-400 mt-1">Injected inside &lt;head&gt; on every page</p>
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 mb-1">Custom Footer Code <span class="text-gray-400 font-normal">(chat widgets, analytics, pixel scripts)</span></label>
              <textarea name="CUSTOM_FOOTER_CODE" rows="3" class="form-input text-sm font-mono resize-none text-xs"
                placeholder="<!-- paste your footer code here -->"><%= settings.CUSTOM_FOOTER_CODE || '' %></textarea>
              <p class="text-xs text-gray-400 mt-1">Injected before &lt;/body&gt; on every page</p>
            </div>
          </div>
        </div>

        <!-- SETTINGS SUMMARY -->
        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-5">
          <h4 class="font-bold text-blue-800 mb-3">&#x1F4CB; All 36 Settings on This Page</h4>
          <div class="grid md:grid-cols-2 gap-y-1 gap-x-4 text-xs text-blue-700">
            <span>1. Stripe Publishable Key</span><span>2. Stripe Secret Key</span>
            <span>3. PayPal Client ID</span><span>4. PayPal Client Secret + Mode</span>
            <span>5. Site Name</span><span>6. Site URL</span>
            <span>7. Site Tagline</span><span>8. Promo Banner (text, code, on/off)</span>
            <span>9. Contact Email</span><span>10. Gmail App Password</span>
            <span>11. Support WhatsApp Number</span><span>12. Instagram URL</span>
            <span>13. TikTok URL</span><span>14. YouTube URL</span>
            <span>15. Facebook URL</span><span>16. Twitter / X URL</span>
            <span>17. LinkedIn URL</span><span>18. Currency + Symbol</span>
            <span>19. Default Download Limit</span><span>20. Free Guide Download Limit</span>
            <span>21. Google Analytics ID</span><span>22. Meta Description</span>
            <span>23. Meta Keywords</span><span>24. Facebook Pixel ID</span>
            <span>25. Tawk.to Chat Widget ID</span><span>26. Admin Email + Password</span>
            <span>27. Allow Registrations</span><span>28. Maintenance Mode</span>
            <span>29. Require Email Verification</span><span>30. Logo + Favicon URLs</span>
            <span>31. Brand Color</span><span>32. Footer + Copyright Text</span>
            <span>33. Homepage Hero Title + Subtitle</span><span>34. SMTP Email Server</span>
            <span>35. Tax / VAT Rate + Label</span><span>36. Custom Head + Footer Code</span>
          </div>
        </div>

        <button type="submit" class="w-full bg-rescue-red text-white py-4 rounded-xl font-black text-base hover:bg-red-700 transition-all shadow-md">
          <i class="fas fa-save mr-2"></i>Save All Settings
        </button>
        <p class="text-center text-xs text-gray-400 mt-2">&#9888;&#65039; On Railway, also update variables in the Railway Variables tab for permanent effect.</p>
      </form>
    </div>
  </main>
</div>
