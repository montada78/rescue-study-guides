<!-- Admin Coupons Page -->
<div class="flex min-h-screen bg-gray-100">
  <!-- Sidebar -->
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0 flex flex-col">
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center space-x-3">
        <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/>
          <path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/>
          <path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/>
          <path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/>
          <path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/>
          <circle cx="50" cy="50" r="18" fill="white"/>
          <text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946" font-family="Poppins,sans-serif">RSG</text>
        </svg>
        <div>
          <div class="font-bold text-rescue-red text-sm leading-none">RESCUE</div>
          <div class="text-xs text-gray-400 tracking-widest">ADMIN</div>
        </div>
      </div>
    </div>
    <nav class="flex-1 p-3 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-tachometer-alt w-4 text-center"></i>Dashboard</a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-book w-4 text-center"></i>Products</a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-plus w-4 text-center"></i>Add Product</a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-shopping-bag w-4 text-center"></i>Orders</a>
      <a href="/admin/coupons" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-rescue-red text-white text-sm font-semibold"><i class="fas fa-tag w-4 text-center"></i>Coupons</a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-folder w-4 text-center"></i>Categories</a>      <a href="/admin/file-recovery" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10"><i class="fas fa-file-medical w-4"></i> File Recovery</a>

      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-300 hover:bg-white/10 text-sm transition-colors"><i class="fas fa-cog w-4 text-center"></i>Settings</a>
    </nav>
    <div class="p-4 border-t border-gray-700">
      <a href="/" class="text-xs text-gray-400 hover:text-white transition-colors"><i class="fas fa-external-link-alt mr-1"></i>View Site</a>
    </div>
  </aside>

  <!-- Main -->
  <main class="flex-1 p-8 overflow-auto">
    <div class="max-w-5xl mx-auto">

      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-display font-black text-2xl text-gray-800">🏷️ Coupon Codes</h1>
          <p class="text-gray-500 text-sm mt-1">Create & manage discount codes for students</p>
        </div>
      </div>

      <!-- Flash messages -->
      <% if (locals.success) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <i class="fas fa-check-circle text-green-500"></i>
        <span class="text-green-700 text-sm font-medium"><%= locals.success %></span>
      </div>
      <% } %>
      <% if (locals.error) { %>
      <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <i class="fas fa-exclamation-circle text-red-500"></i>
        <span class="text-red-700 text-sm font-medium"><%= locals.error %></span>
      </div>
      <% } %>

      <div class="grid lg:grid-cols-3 gap-8">

        <!-- Create Coupon Form -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="font-bold text-gray-800 mb-5 flex items-center gap-2"><i class="fas fa-plus-circle text-rescue-red"></i> New Coupon</h2>
            <form action="/admin/coupons/create" method="POST" class="space-y-4">
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Code *</label>
                <input type="text" name="code" required placeholder="e.g. RESCUE30" maxlength="30"
                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm font-mono font-bold uppercase focus:outline-none focus:border-rescue-red">
                <p class="text-xs text-gray-400 mt-1">Auto-uppercased. Students type this at checkout.</p>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Discount Type *</label>
                <select name="type" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-rescue-red">
                  <option value="percent">% Percentage Off</option>
                  <option value="fixed">$ Fixed Amount Off</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Value *</label>
                <input type="number" name="value" required min="1" step="0.01" placeholder="e.g. 30 for 30% or 5 for $5"
                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-rescue-red">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Min. Order ($)</label>
                <input type="number" name="min_order" min="0" step="0.01" placeholder="0 = no minimum"
                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-rescue-red">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Max Uses</label>
                <input type="number" name="max_uses" min="1" placeholder="Leave blank = unlimited"
                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-rescue-red">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-600 mb-1 uppercase tracking-wide">Expires At</label>
                <input type="datetime-local" name="expires_at"
                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-rescue-red">
              </div>
              <button type="submit" class="w-full bg-rescue-red text-white py-3 rounded-xl font-bold hover:opacity-90 transition-opacity">
                <i class="fas fa-plus mr-2"></i>Create Coupon
              </button>
            </form>
          </div>
        </div>

        <!-- Coupons Table -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-5 border-b border-gray-100 flex items-center justify-between">
              <h2 class="font-bold text-gray-800">All Coupons (<%= coupons.length %>)</h2>
            </div>
            <% if (coupons.length === 0) { %>
            <div class="text-center py-16 text-gray-400">
              <div class="text-5xl mb-3">🏷️</div>
              <p class="font-medium">No coupons yet</p>
              <p class="text-sm mt-1">Create your first discount code on the left</p>
            </div>
            <% } else { %>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
                  <tr>
                    <th class="px-4 py-3 text-left">Code</th>
                    <th class="px-4 py-3 text-left">Discount</th>
                    <th class="px-4 py-3 text-left">Uses</th>
                    <th class="px-4 py-3 text-left">Expires</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% coupons.forEach(c => { %>
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">
                      <span class="font-mono font-bold text-gray-800 bg-gray-100 px-2 py-0.5 rounded-lg text-sm"><%= c.code %></span>
                    </td>
                    <td class="px-4 py-3">
                      <span class="font-bold text-rescue-red">
                        <%= c.type === 'percent' ? c.value + '% OFF' : '$' + c.value.toFixed(2) + ' OFF' %>
                      </span>
                      <% if (c.min_order > 0) { %>
                      <span class="text-xs text-gray-400 block">min $<%= c.min_order.toFixed(2) %></span>
                      <% } %>
                    </td>
                    <td class="px-4 py-3 text-gray-600">
                      <%= c.uses_count %><% if (c.max_uses) { %>/<%= c.max_uses %><% } else { %><span class="text-gray-400">/∞</span><% } %>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-xs">
                      <% if (c.expires_at) { %>
                        <%= new Date(c.expires_at).toLocaleDateString() %>
                      <% } else { %>
                        <span class="text-gray-400">Never</span>
                      <% } %>
                    </td>
                    <td class="px-4 py-3">
                      <button onclick="toggleCoupon(<%= c.id %>, this)"
                        class="px-2.5 py-1 rounded-full text-xs font-bold transition-all <%= c.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                        <%= c.is_active ? '✅ Active' : '❌ Off' %>
                      </button>
                    </td>
                    <td class="px-4 py-3">
                      <form action="/admin/coupons/delete/<%= c.id %>" method="POST" onsubmit="return confirm('Delete coupon <%= c.code %>?')" class="inline">
                        <button type="submit" class="text-red-400 hover:text-red-600 transition-colors">
                          <i class="fas fa-trash text-xs"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
function toggleCoupon(id, btn) {
  fetch('/admin/coupons/toggle/' + id, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        btn.textContent = data.active ? '✅ Active' : '❌ Off';
        btn.className = 'px-2.5 py-1 rounded-full text-xs font-bold transition-all ' +
          (data.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500');
      }
    });
}
</script>
