<!-- Admin Products List -->
<div class="flex min-h-screen bg-gray-100">
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0">
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center gap-3">
        <svg width="36" height="36" viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/><path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/><path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/><path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/><path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/><circle cx="50" cy="50" r="18" fill="white"/><text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946">RSG</text></svg>
        <div><p class="font-display font-black text-sm text-rescue-red">RESCUE</p><p class="text-xs text-gray-400">Admin Panel</p></div>
      </div>
    </div>
    <nav class="p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tachometer-alt w-4 text-rescue-red"></i> Dashboard</a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium bg-rescue-red text-white"><i class="fas fa-book w-4"></i> Products</a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-plus-circle w-4 text-green-400"></i> Add Guide</a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-receipt w-4 text-rescue-red"></i> Orders</a>
      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-users w-4 text-rescue-red"></i> Users</a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tags w-4 text-rescue-red"></i> Categories</a>
      <a href="/admin/coupons" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-ticket-alt w-4 text-rescue-red"></i> Coupons</a>
      <a href="/admin/access-codes" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-key w-4 text-rescue-red"></i> Access Codes</a>
      <div class="pt-4 border-t border-gray-700 mt-4">
        <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-cog w-4 text-rescue-red"></i> Settings</a>
      <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-gray-700 text-gray-400"><i class="fas fa-external-link-alt w-4"></i> View Site</a>
        <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-red-900/30 hover:text-red-400 text-gray-400"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
      </div>
    </nav>
  </aside>

  <main class="flex-1 overflow-auto">
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <h1 class="font-display font-bold text-xl text-gray-800">Manage Products (<%= products.length %>)</h1>
      <a href="/admin/products/new" class="bg-rescue-red text-white px-4 py-2.5 rounded-xl font-semibold text-sm hover:bg-rescue-red-dark transition-colors flex items-center gap-2">
        <i class="fas fa-plus"></i> Add New Guide
      </a>
    </div>

    <div class="p-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                <th class="px-6 py-4">Guide</th>
                <th class="px-4 py-4">Subject</th>
                <th class="px-4 py-4">Level</th>
                <th class="px-4 py-4">Price</th>
                <th class="px-4 py-4">File</th>
                <th class="px-4 py-4">Downloads</th>
                <th class="px-4 py-4">Status</th>
                <th class="px-4 py-4">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% products.forEach(product => { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-rescue-red/10 flex items-center justify-center text-xl flex-shrink-0">
                      <%= product.subject === 'Chemistry' ? '⚗️' : product.subject === 'Biology' ? '🧬' : product.subject === 'Mathematics' ? '🔢' : product.subject === 'Physics' ? '⚡' : '📚' %>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-800 line-clamp-1 max-w-xs"><%= product.title %></p>
                      <p class="text-xs text-gray-400"><%= product.category_name %> • <%= product.curriculum %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-4 text-gray-600"><%= product.subject %></td>
                <td class="px-4 py-4">
                  <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full font-medium"><%= product.level %></span>
                </td>
                <td class="px-4 py-4">
                  <% if (product.is_free || product.price === 0) { %>
                    <span class="font-bold text-green-600">FREE</span>
                  <% } else { %>
                    <span class="font-bold text-rescue-red">$<%= product.price.toFixed(2) %></span>
                  <% } %>
                </td>
                <td class="px-4 py-4">
                  <% if (product.file_name) { %>
                    <span class="inline-flex items-center gap-1 text-xs bg-green-100 text-green-700 px-2.5 py-1 rounded-full font-medium">
                      <i class="fas fa-file-pdf"></i> PDF ✅
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 text-xs bg-red-100 text-red-500 px-2.5 py-1 rounded-full font-medium">
                      <i class="fas fa-times"></i> No file
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-4 text-gray-600"><%= product.downloads_count %></td>
                <td class="px-4 py-4">
                  <button onclick="toggleProduct(<%= product.id %>, this)" 
                    class="px-3 py-1.5 rounded-full text-xs font-bold transition-colors <%= product.is_active ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200' %>">
                    <%= product.is_active ? '✅ Active' : '⭕ Inactive' %>
                  </button>
                </td>
                <td class="px-4 py-4">
                  <div class="flex items-center gap-2">
                    <a href="/admin/products/edit/<%= product.id %>" class="w-8 h-8 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center hover:bg-blue-200 transition-colors" title="Edit">
                      <i class="fas fa-edit text-xs"></i>
                    </a>
                    <a href="/product/<%= product.slug %>" target="_blank" class="w-8 h-8 bg-gray-100 text-gray-600 rounded-lg flex items-center justify-center hover:bg-gray-200 transition-colors" title="Preview">
                      <i class="fas fa-eye text-xs"></i>
                    </a>
                    <form action="/admin/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this product permanently?')">
                      <button type="submit" class="w-8 h-8 bg-red-100 text-red-600 rounded-lg flex items-center justify-center hover:bg-red-200 transition-colors" title="Delete">
                        <i class="fas fa-trash text-xs"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
async function toggleProduct(id, btn) {
  const res = await fetch(`/admin/products/toggle/${id}`, { method: 'POST' });
  const data = await res.json();
  if (data.success) {
    btn.className = data.active 
      ? 'px-3 py-1.5 rounded-full text-xs font-bold transition-colors bg-green-100 text-green-700 hover:bg-green-200'
      : 'px-3 py-1.5 rounded-full text-xs font-bold transition-colors bg-gray-100 text-gray-500 hover:bg-gray-200';
    btn.textContent = data.active ? '✅ Active' : '⭕ Inactive';
  }
}
</script>
