<!-- Admin Dashboard Layout -->
<div class="flex min-h-screen bg-gray-100">
  <!-- Sidebar -->
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0 flex flex-col">
    <!-- Logo -->
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center gap-3">
        <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/>
          <path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/>
          <path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/>
          <path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/>
          <path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/>
          <circle cx="50" cy="50" r="18" fill="white"/>
          <text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946" font-family="Poppins,sans-serif">RSG</text>
        </svg>
        <div>
          <p class="font-display font-black text-sm text-rescue-red">RESCUE</p>
          <p class="text-xs text-gray-400">Admin Panel</p>
        </div>
      </div>
    </div>

    <!-- Nav -->
    <nav class="p-4 flex-1 space-y-1">
      <% const currentPath = locals.currentPath || ''; %>
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-tachometer-alt w-4 text-rescue-red"></i> Dashboard
      </a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-book w-4 text-rescue-red"></i> Products
      </a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-plus-circle w-4 text-green-500"></i> Add Guide
      </a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-receipt w-4 text-rescue-red"></i> Orders
      </a>
      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-users w-4 text-rescue-red"></i> Users
      </a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 hover:text-white transition-colors text-gray-300">
        <i class="fas fa-tags w-4 text-rescue-red"></i> Categories
      </a>
      <div class="pt-4 border-t border-gray-700 mt-4 space-y-1">      <a href="/admin/file-recovery" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10"><i class="fas fa-file-medical w-4"></i> File Recovery</a>

        <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-cog w-4 text-rescue-red"></i> Settings</a>
      <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-gray-700 transition-colors text-gray-400">
          <i class="fas fa-external-link-alt w-4"></i> View Site
        </a>
        <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-red-900/30 hover:text-red-400 transition-colors text-gray-400">
          <i class="fas fa-sign-out-alt w-4"></i> Logout
        </a>
      </div>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 overflow-auto">
    <!-- Top Bar -->
    <div class="bg-white shadow-sm px-8 py-4 flex items-center justify-between">
      <h1 class="font-display font-bold text-xl text-gray-800">Admin Dashboard</h1>
      <div class="flex items-center gap-3">
        <span class="text-sm text-gray-500">Admin: <%= user?.name || 'Admin' %></span>
        <div class="w-8 h-8 bg-rescue-red rounded-full flex items-center justify-center text-white font-bold text-sm">
          <%= user?.name?.charAt(0) || 'A' %>
        </div>
      </div>
    </div>

    <div class="p-8">
      <!-- Stats Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Students</p>
            <div class="w-8 h-8 bg-blue-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-users text-xs text-blue-600"></i>
            </div>
          </div>
          <p class="font-black text-2xl text-gray-800"><%= stats.totalUsers %></p>
        </div>
        
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Products</p>
            <div class="w-8 h-8 bg-purple-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-book text-xs text-purple-600"></i>
            </div>
          </div>
          <p class="font-black text-2xl text-gray-800"><%= stats.totalProducts %></p>
        </div>
        
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Orders</p>
            <div class="w-8 h-8 bg-yellow-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-receipt text-xs text-yellow-600"></i>
            </div>
          </div>
          <p class="font-black text-2xl text-gray-800"><%= stats.totalOrders %></p>
        </div>
        
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Revenue</p>
            <div class="w-8 h-8 bg-green-100 rounded-xl flex items-center justify-center">
              <i class="fas fa-dollar-sign text-xs text-green-600"></i>
            </div>
          </div>
          <p class="font-black text-2xl text-green-600">$<%= stats.totalRevenue.toFixed(2) %></p>
        </div>
        
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Downloads</p>
            <div class="w-8 h-8 bg-rescue-red/10 rounded-xl flex items-center justify-center">
              <i class="fas fa-download text-xs text-rescue-red"></i>
            </div>
          </div>
          <p class="font-black text-2xl text-rescue-red"><%= stats.totalDownloads %></p>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Recent Orders -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-base text-gray-800">Recent Orders</h2>
            <a href="/admin/orders" class="text-rescue-red text-xs font-semibold">View All →</a>
          </div>
          <div class="space-y-3">
            <% stats.recentOrders.slice(0, 8).forEach(order => { %>
            <div class="flex items-center justify-between py-2 border-b border-gray-50">
              <div>
                <p class="text-sm font-semibold text-gray-800"><%= order.order_number %></p>
                <p class="text-xs text-gray-500"><%= order.user_name %></p>
              </div>
              <div class="text-right">
                <p class="font-bold text-sm text-green-600">$<%= order.total_amount.toFixed(2) %></p>
                <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-medium"><%= order.status %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Top Products -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-base text-gray-800">Top Products</h2>
            <a href="/admin/products" class="text-rescue-red text-xs font-semibold">Manage →</a>
          </div>
          <div class="space-y-3">
            <% stats.topProducts.forEach((product, idx) => { %>
            <div class="flex items-center gap-3 py-2 border-b border-gray-50">
              <div class="w-7 h-7 rounded-full bg-rescue-red/10 flex items-center justify-center text-xs font-black text-rescue-red">#<%= idx + 1 %></div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-800 truncate"><%= product.title %></p>
                <p class="text-xs text-gray-500"><%= product.downloads_count %> downloads</p>
              </div>
              <p class="font-bold text-sm text-rescue-red flex-shrink-0">$<%= product.price.toFixed(2) %></p>
            </div>
            <% }) %>
          </div>

          <div class="mt-5 pt-4 border-t border-gray-100">
            <a href="/admin/products/new" class="flex items-center justify-center gap-2 bg-rescue-red text-white px-4 py-2.5 rounded-xl font-semibold text-sm hover:bg-rescue-red-dark transition-colors w-full">
              <i class="fas fa-plus"></i>
              Upload New Study Guide
            </a>
          </div>
        </div>

        <!-- Recent Users -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:col-span-2">
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-base text-gray-800">Recent Registrations</h2>
            <a href="/admin/users" class="text-rescue-red text-xs font-semibold">View All →</a>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-xs font-semibold text-gray-500 border-b border-gray-100">
                  <th class="pb-3 pr-4">Name</th>
                  <th class="pb-3 pr-4">Email</th>
                  <th class="pb-3 pr-4">Level</th>
                  <th class="pb-3 pr-4">Country</th>
                  <th class="pb-3">Joined</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% stats.recentUsers.slice(0, 6).forEach(u => { %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="py-3 pr-4 font-semibold text-gray-800">
                    <div class="flex items-center gap-2">
                      <div class="w-7 h-7 bg-rescue-red/10 rounded-full flex items-center justify-center text-xs font-bold text-rescue-red"><%= u.name.charAt(0) %></div>
                      <%= u.name %>
                    </div>
                  </td>
                  <td class="py-3 pr-4 text-gray-600"><%= u.email %></td>
                  <td class="py-3 pr-4 text-gray-600"><%= u.grade_level || '—' %></td>
                  <td class="py-3 pr-4 text-gray-600"><%= u.country || '—' %></td>
                  <td class="py-3 text-gray-400"><%= new Date(u.created_at).toLocaleDateString() %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
