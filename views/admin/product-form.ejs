<!-- Admin Product Form -->
<div class="flex min-h-screen bg-gray-100">
  <!-- Sidebar (same as dashboard) -->
  <aside class="w-60 bg-rescue-dark text-white flex-shrink-0">
    <div class="p-5 border-b border-gray-700">
      <div class="flex items-center gap-3">
        <svg width="36" height="36" viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/><path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/><path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/><path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/><path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/><circle cx="50" cy="50" r="18" fill="white"/><text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946">RSG</text></svg>
        <div><p class="font-display font-black text-sm text-rescue-red">RESCUE</p><p class="text-xs text-gray-400">Admin Panel</p></div>
      </div>
    </div>
    <nav class="p-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tachometer-alt w-4 text-rescue-red"></i> Dashboard</a>
      <a href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-book w-4 text-rescue-red"></i> Products</a>
      <a href="/admin/products/new" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium bg-rescue-red text-white"><i class="fas fa-plus-circle w-4"></i> Add Guide</a>
      <a href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-receipt w-4 text-rescue-red"></i> Orders</a>
      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-users w-4 text-rescue-red"></i> Users</a>
      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium hover:bg-rescue-red/20 text-gray-300"><i class="fas fa-tags w-4 text-rescue-red"></i> Categories</a>
    </nav>
  </aside>

  <!-- Main -->
  <main class="flex-1 overflow-auto">
    <div class="bg-white shadow-sm px-8 py-4 flex items-center gap-4">
      <a href="/admin/products" class="text-gray-500 hover:text-rescue-red"><i class="fas fa-arrow-left"></i></a>
      <h1 class="font-display font-bold text-xl text-gray-800"><%= product ? 'Edit' : 'Add New' %> Study Guide</h1>
    </div>

    <div class="p-8">
      <form id="productForm" action="/admin/products/<%= product ? 'edit/' + product.id : 'new' %>" method="POST" enctype="multipart/form-data">
        <div class="grid lg:grid-cols-3 gap-6">
          
          <!-- Main Fields -->
          <div class="lg:col-span-2 space-y-5">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-gray-700 mb-4">Basic Information</h3>
              
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Guide Title *</label>
                  <input type="text" name="title" required value="<%= product?.title || '' %>" placeholder="e.g. IGCSE Chemistry Complete Rescue Guide"
                    class="form-input">
                </div>
                
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Short Description *</label>
                  <input type="text" name="short_description" value="<%= product?.short_description || '' %>" placeholder="Brief one-line summary for cards"
                    class="form-input">
                </div>
                
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Description</label>
                  <textarea name="description" rows="5" placeholder="Detailed description of what this guide covers..."
                    class="form-input resize-none"><%= product?.description || '' %></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Subject *</label>
                    <input type="text" name="subject" required value="<%= product?.subject || '' %>" placeholder="e.g. Chemistry" class="form-input">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Level *</label>
                    <select name="level" class="form-input">
                      <% ['IGCSE', 'AP', 'SABIS', 'High School', 'Grade 9', 'Grade 10', 'Grade 11', 'Grade 12', 'Beginner', 'University'].forEach(l => { %>
                      <option value="<%= l %>" <%= product?.level === l ? 'selected' : '' %>><%= l %></option>
                      <% }) %>
                    </select>
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Curriculum</label>
                    <select name="curriculum" class="form-input">
                      <% ['IGCSE Cambridge', 'AP College Board', 'SABIS', 'American Curriculum', 'IB', 'Edexcel', 'General'].forEach(c => { %>
                      <option value="<%= c %>" <%= product?.curriculum === c ? 'selected' : '' %>><%= c %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Number of Pages</label>
                    <input type="number" name="pages" value="<%= product?.pages || 0 %>" min="0" class="form-input">
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Category</label>
                  <select name="category_id" class="form-input">
                    <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= product?.category_id === cat.id ? 'selected' : '' %>><%= cat.icon %> <%= cat.name %></option>
                    <% }) %>
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tags (comma-separated)</label>
                  <input type="text" name="tags" value="<%= product?.tags || '' %>" placeholder="igcse,chemistry,organic,revision" class="form-input">
                </div>
              </div>
            </div>

            <!-- File Upload -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-gray-700 mb-4">📎 File Upload</h3>
              
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                    PDF Study Guide File
                    <% if (product?.file_name) { %><span class="text-green-600 font-normal ml-2">✅ Current: <%= product.file_name %></span><% } %>
                  </label>

                  <!-- Drop zone -->
                  <label for="pdf_file" id="pdfLabel" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-rescue-red transition-colors cursor-pointer block">
                    <i class="fas fa-file-pdf text-3xl text-red-400 mb-2 block"></i>
                    <p id="pdfLabelText" class="text-sm text-gray-600 font-medium">Click here to choose a PDF file</p>
                    <p class="text-xs text-gray-400 mt-1">.pdf only · Max 200 MB</p>
                  </label>
                  <input type="file" name="pdf_file" id="pdf_file" accept=".pdf" class="hidden">

                  <!-- Upload Now button — appears after file chosen -->
                  <button type="button" id="uploadNowBtn"
                    class="hidden w-full mt-3 bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition-all shadow-md"
                    onclick="startUpload()">
                    <i class="fas fa-cloud-upload-alt mr-2"></i>
                    <span id="uploadNowText">Upload PDF Now</span>
                  </button>

                  <!-- Progress Bar -->
                  <div id="uploadProgressWrap" class="hidden mt-3">
                    <div class="flex justify-between text-xs text-gray-500 mb-1">
                      <span id="uploadFileName" class="truncate max-w-xs font-medium"></span>
                      <span id="uploadPercent" class="font-bold text-blue-600">0%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-4 overflow-hidden">
                      <div id="uploadBar" class="bg-blue-600 h-4 rounded-full transition-all duration-300" style="width:0%"></div>
                    </div>
                    <p id="uploadStatus" class="text-xs text-gray-500 mt-1.5">Waiting…</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-5">
            <!-- Pricing -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-gray-700 mb-4">💰 Pricing</h3>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Price (USD) *</label>
                  <input type="number" name="price" required value="<%= product?.price || 0 %>" min="0" step="0.01" placeholder="9.99" class="form-input">
                </div>
                <div>
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Original Price (for discount)</label>
                  <input type="number" name="original_price" value="<%= product?.original_price || '' %>" min="0" step="0.01" placeholder="14.99" class="form-input">
                </div>
              </div>
            </div>

            <!-- Images -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-gray-700 mb-4">🖼️ Cover Image</h3>
              <% if (product?.cover_image) { %>
              <img src="<%= product.cover_image %>" class="w-full h-32 object-cover rounded-xl mb-3">
              <% } %>
              <input type="file" name="cover_image" accept="image/*" class="w-full text-xs text-gray-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:bg-rescue-red/10 file:text-rescue-red hover:file:bg-rescue-red/20 cursor-pointer">
            </div>

            <!-- Status -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-gray-700 mb-4">⚙️ Settings</h3>
              <div class="space-y-3">
                <label class="flex items-center justify-between cursor-pointer">
                  <span class="text-sm text-gray-700">Active / Published</span>
                  <div class="relative">
                    <input type="checkbox" name="is_active" <%= !product || product.is_active ? 'checked' : '' %> class="sr-only peer">
                    <div class="w-10 h-6 bg-gray-200 rounded-full peer-checked:bg-rescue-red transition-colors peer peer-focus:ring-2 peer-focus:ring-rescue-red/30 cursor-pointer" onclick="this.previousElementSibling.click()"></div>
                    <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4 pointer-events-none"></div>
                  </div>
                </label>
                <label class="flex items-center justify-between cursor-pointer">
                  <span class="text-sm text-gray-700">Featured on Homepage</span>
                  <input type="checkbox" name="is_featured" <%= product?.is_featured ? 'checked' : '' %> class="w-4 h-4 rounded accent-rescue-red">
                </label>
                <label class="flex items-center justify-between cursor-pointer">
                  <span class="text-sm text-gray-700">Free Download</span>
                  <input type="checkbox" name="is_free" <%= product?.is_free ? 'checked' : '' %> class="w-4 h-4 rounded accent-rescue-red">
                </label>
              </div>
            </div>

            <!-- Submit -->
            <button type="button" id="submitBtn" onclick="saveGuide()"
              class="w-full bg-rescue-red text-white py-3.5 rounded-xl font-bold hover:bg-rescue-red-dark transition-all shadow-md hover:scale-[1.02]">
              <i class="fas fa-<%= product ? 'save' : 'plus' %> mr-2"></i>
              <span id="submitText"><%= product ? 'Update Guide' : 'Save Guide' %></span>
            </button>
            
            <% if (product) { %>
            <form action="/admin/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this guide permanently?')">
              <button type="submit" class="w-full border-2 border-red-200 text-red-500 py-2.5 rounded-xl font-semibold text-sm hover:bg-red-50 transition-colors">
                <i class="fas fa-trash mr-2"></i>Delete Guide
              </button>
            </form>
            <% } %>
          </div>
        </div>
      </form>
    </div>
  </main>

</div>
<script src="/js/product-form.js"></script>
