<!-- Register Page -->
<div class="min-h-screen bg-gradient-to-br from-red-50 to-white flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-lg">
    <!-- Logo -->
    <div class="text-center mb-8">
      <a href="/" class="inline-flex flex-col items-center">
        <svg width="56" height="56" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="mb-3">
          <circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/>
          <path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/>
          <path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/>
          <path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/>
          <path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/>
          <circle cx="50" cy="50" r="18" fill="white"/>
          <text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946" font-family="Poppins,sans-serif">K-C</text>
        </svg>
        <span class="font-display font-black text-2xl text-rescue-red">K-Chemistry</span>
      </a>
      <h1 class="font-display font-bold text-2xl text-gray-800 mt-4">Create Your Free Account 🎓</h1>
      <p class="text-gray-500 text-sm mt-1">Join 10,000+ students acing their exams</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8">
      <% if (error) { %>
      <div class="bg-red-50 border-l-4 border-rescue-red rounded-xl p-4 mb-6 flex items-center gap-3">
        <i class="fas fa-exclamation-circle text-rescue-red"></i>
        <p class="text-red-700 text-sm font-medium"><%= error %></p>
      </div>
      <% } %>

      <form action="/auth/register" method="POST" class="space-y-4">
        <!-- Name -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
          <div class="relative">
            <i class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="text" name="name" required placeholder="Your full name" autocomplete="name" class="form-input pl-11">
          </div>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
          <div class="relative">
            <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="email" name="email" required placeholder="your@email.com" autocomplete="email" class="form-input pl-11">
          </div>
        </div>

        <!-- Password Row -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password *</label>
            <div class="relative">
              <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
              <input type="password" name="password" required placeholder="Min 8 chars" autocomplete="new-password" class="form-input pl-11" id="password">
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirm *</label>
            <div class="relative">
              <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
              <input type="password" name="confirmPassword" required placeholder="Repeat password" autocomplete="new-password" class="form-input pl-11" id="confirmPassword">
            </div>
          </div>
        </div>

        <!-- School & Grade Row -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">School (Optional)</label>
            <input type="text" name="school" placeholder="Your school name" class="form-input">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Level</label>
            <select name="grade_level" class="form-input">
              <option value="">-- Select --</option>
              <option>IGCSE Year 10</option>
              <option>IGCSE Year 11</option>
              <option>AP Year 11</option>
              <option>AP Year 12</option>
              <option>SABIS Grade 9</option>
              <option>SABIS Grade 10</option>
              <option>SABIS Grade 11</option>
              <option>SABIS Grade 12</option>
              <option>University</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <!-- Country -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Country (Optional)</label>
          <div class="relative">
            <i class="fas fa-globe absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <select name="country" class="form-input pl-11">
              <option value="">-- Select Country --</option>
              <option>United Arab Emirates</option>
              <option>Saudi Arabia</option>
              <option>United Kingdom</option>
              <option>United States</option>
              <option>Egypt</option>
              <option>Qatar</option>
              <option>Kuwait</option>
              <option>Jordan</option>
              <option>Lebanon</option>
              <option>Australia</option>
              <option>Canada</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <!-- Terms -->
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" name="terms" required class="mt-0.5 w-4 h-4 rounded border-gray-300 accent-rescue-red">
          <span class="text-sm text-gray-600">
            I agree to the <a href="#" class="text-rescue-red font-semibold hover:underline">Terms of Service</a> 
            and <a href="#" class="text-rescue-red font-semibold hover:underline">Privacy Policy</a>
          </span>
        </label>

        <button type="submit" class="w-full bg-rescue-red text-white py-3.5 rounded-xl font-bold text-base hover:bg-rescue-red-dark transition-all hover:scale-[1.02] shadow-md mt-2">
          <i class="fas fa-user-plus mr-2"></i>Create Free Account 🚀
        </button>
      </form>

      <div class="mt-6 text-center">
        <p class="text-gray-500 text-sm">
          Already have an account? 
          <a href="/auth/login" class="text-rescue-red font-bold hover:underline ml-1">Sign In</a>
        </p>
      </div>
    </div>

    <!-- Perks -->
    <div class="mt-6 grid grid-cols-3 gap-3 text-center">
      <div class="bg-white rounded-2xl p-3 shadow-sm border border-gray-100">
        <div class="text-lg mb-1">🎁</div>
        <p class="text-xs text-gray-600 font-medium">Free Guide on Signup</p>
      </div>
      <div class="bg-white rounded-2xl p-3 shadow-sm border border-gray-100">
        <div class="text-lg mb-1">⚡</div>
        <p class="text-xs text-gray-600 font-medium">Instant Downloads</p>
      </div>
      <div class="bg-white rounded-2xl p-3 shadow-sm border border-gray-100">
        <div class="text-lg mb-1">🔒</div>
        <p class="text-xs text-gray-600 font-medium">Secure & Private</p>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('confirmPassword')?.addEventListener('input', function() {
  const pwd = document.getElementById('password').value;
  if (this.value && this.value !== pwd) {
    this.style.borderColor = '#E63946';
  } else {
    this.style.borderColor = '';
  }
});
</script>
