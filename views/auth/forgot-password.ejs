<!-- Forgot Password -->
<div class="min-h-screen bg-gradient-to-br from-red-50 to-white flex items-center justify-center py-16 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/" class="inline-block mb-4">
        <svg width="56" height="56" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="48" fill="none" stroke="#E63946" stroke-width="4"/>
          <path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="#E63946"/>
          <path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="#E63946"/>
          <path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="#E63946"/>
          <path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="#E63946"/>
          <circle cx="50" cy="50" r="18" fill="white"/>
          <text x="50" y="56" text-anchor="middle" font-size="14" font-weight="bold" fill="#E63946" font-family="Poppins,sans-serif">K-C</text>
        </svg>
      </a>
      <h1 class="font-display font-bold text-2xl text-gray-800">Reset Your Password 🔑</h1>
      <p class="text-gray-500 text-sm mt-1">Enter your email and we'll send you a reset link</p>
    </div>

    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8">
      <% if (sent) { %>
      <div class="text-center py-4">
        <div class="text-6xl mb-4">📧</div>
        <h3 class="font-display font-bold text-xl text-gray-800 mb-2">Check Your Email!</h3>
        <p class="text-gray-500 text-sm mb-6">If that email is registered with us, you'll receive a password reset link shortly.</p>
        <a href="/auth/login" class="btn-rescue w-full justify-center">Back to Login</a>
      </div>
      <% } else { %>
      <form action="/auth/forgot-password" method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
          <div class="relative">
            <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="email" name="email" required placeholder="your@email.com" class="form-input pl-11">
          </div>
        </div>
        <button type="submit" class="w-full bg-rescue-red text-white py-3.5 rounded-xl font-bold hover:bg-rescue-red-dark transition-all shadow-md">
          <i class="fas fa-paper-plane mr-2"></i>Send Reset Link
        </button>
      </form>
      <div class="mt-5 text-center">
        <a href="/auth/login" class="text-gray-500 text-sm hover:text-rescue-red transition-colors">
          <i class="fas fa-arrow-left mr-1"></i>Back to Login
        </a>
      </div>
      <% } %>
    </div>
  </div>
</div>
