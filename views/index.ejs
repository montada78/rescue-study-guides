<!-- FREE GUIDE CTA -->
<% if (freeGuides.length > 0) { %>
<section class="py-14 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="bg-gradient-to-br from-rescue-red to-red-800 rounded-3xl p-10 text-white relative overflow-hidden">
      <div class="absolute top-4 right-4 opacity-10 spin-slow">
