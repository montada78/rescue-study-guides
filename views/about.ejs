<!-- ABOUT PAGE -->
<div class="page-hero">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display font-black text-5xl mb-3">About Rescue Study Guides</h1>
    <p class="text-white/80 text-xl max-w-2xl mx-auto">We turn exam panic into exam confidence — one colorful guide at a time 🚀</p>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <!-- Mission -->
  <div class="grid lg:grid-cols-2 gap-12 items-center mb-16">
    <div>
      <span class="inline-block bg-red-100 text-rescue-red text-sm font-bold px-4 py-1.5 rounded-full mb-4">🎯 OUR MISSION</span>
      <h2 class="font-display font-black text-4xl text-gray-800 mb-5 leading-tight">
        From "I Don't Get It" to<br><span class="text-rescue-red">"I Ace It"</span>
      </h2>
      <p class="text-gray-600 leading-relaxed mb-4 text-lg">
        Rescue Study Guides was born from a simple truth: students learn better when content is beautiful, organized, and actually engaging. We create premium, colorful, Gen Z-friendly revision guides that make studying feel less like a chore and more like a superpower.
      </p>
      <p class="text-gray-600 leading-relaxed text-lg">
        Whether you're tackling IGCSE, AP, SABIS, or American curriculum — we've got the guide that rescues your grade. 💪
      </p>
    </div>
    <div class="relative">
      <div class="bg-gradient-to-br from-rescue-red to-red-700 rounded-3xl p-10 text-white text-center shadow-2xl">
        <svg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-5 spin-slow">
          <circle cx="50" cy="50" r="48" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="4"/>
          <path d="M50 2 A48 48 0 0 1 98 50 L78 50 A28 28 0 0 0 50 22 Z" fill="white"/>
          <path d="M98 50 A48 48 0 0 1 50 98 L50 78 A28 28 0 0 0 78 50 Z" fill="white"/>
          <path d="M50 98 A48 48 0 0 1 2 50 L22 50 A28 28 0 0 0 50 78 Z" fill="white"/>
          <path d="M2 50 A48 48 0 0 1 50 2 L50 22 A28 28 0 0 0 22 50 Z" fill="white"/>
          <circle cx="50" cy="50" r="18" fill="#E63946"/>
        </svg>
        <p class="font-display font-black text-3xl mb-2">10,000+</p>
        <p class="text-white/80">Students Rescued Worldwide 🌍</p>
        <div class="grid grid-cols-3 gap-4 mt-6 pt-6 border-t border-white/20">
          <div><p class="font-black text-2xl">50+</p><p class="text-white/70 text-xs">Guides</p></div>
          <div><p class="font-black text-2xl">4.9★</p><p class="text-white/70 text-xs">Rating</p></div>
          <div><p class="font-black text-2xl">30+</p><p class="text-white/70 text-xs">Countries</p></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Values -->
  <div class="mb-16">
    <div class="text-center mb-10">
      <h2 class="font-display font-black text-3xl text-gray-800">Why Students Love Us</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <% [
        { icon: '🎨', title: 'Beautiful Design', desc: 'Every guide is crafted to be visually stunning — color-coded, structured, and easy on the eyes. Because boring notes = forgotten notes.' },
        { icon: '🎯', title: 'Exam-Focused', desc: 'We cut the fluff. Every page is packed with exactly what you need to know for your specific exam — IGCSE, AP, SABIS, and more.' },
        { icon: '⚡', title: 'Instant Access', desc: 'Buy once, download instantly. No waiting, no shipping. Study anywhere, anytime, on any device.' },
        { icon: '✅', title: 'Teacher-Approved', desc: 'Written and reviewed by experienced educators who know exactly what examiners are looking for.' },
        { icon: '💰', title: 'Affordable', desc: 'Premium quality at student-friendly prices. We believe every student deserves top-quality resources — not just the wealthy ones.' },
        { icon: '🌍', title: 'Global & Inclusive', desc: 'Guides for all major curriculums used worldwide. Whether you\'re in the UAE, UK, USA, or anywhere in between.' },
      ].forEach(v => { %>
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:-translate-y-1 transition-all">
        <div class="text-4xl mb-3"><%= v.icon %></div>
        <h3 class="font-display font-bold text-lg text-gray-800 mb-2"><%= v.title %></h3>
        <p class="text-gray-600 text-sm leading-relaxed"><%= v.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-gradient-to-br from-rescue-red to-red-700 rounded-3xl p-10 text-white text-center">
    <h2 class="font-display font-black text-3xl mb-3">Ready to Rescue Your Grades? 🚀</h2>
    <p class="text-white/80 mb-6 text-lg">Join thousands of students who went from struggling to scoring. Start today — your first free guide is waiting!</p>
    <a href="/shop" class="bg-white text-rescue-red px-8 py-4 rounded-xl font-black text-base hover:bg-yellow-50 transition-all hover:scale-105 inline-flex items-center shadow-xl">
      <i class="fas fa-shopping-bag mr-2"></i>Browse All Study Guides
    </a>
  </div>
</div>
