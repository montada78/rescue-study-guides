<!-- CHECKOUT PAGE -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="font-display font-black text-3xl text-gray-800 mb-8">🔒 Secure Checkout</h1>
  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Payment Form -->
    <div>
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mb-5">
        <h3 class="font-display font-bold text-lg mb-4">Payment Details</h3>
        <form action="/cart/checkout/process" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Name on Card</label>
            <input type="text" name="card_name" placeholder="John Smith" class="form-input" required>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Card Number</label>
            <div class="relative">
              <i class="fas fa-credit-card absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
              <input type="text" placeholder="4242 4242 4242 4242" class="form-input pl-11" maxlength="19" oninput="formatCard(this)">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Expiry</label>
              <input type="text" placeholder="MM/YY" class="form-input" maxlength="5">
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">CVV</label>
              <input type="text" placeholder="123" class="form-input" maxlength="4">
            </div>
          </div>
          <input type="hidden" name="payment_method" value="card">
          <button type="submit" class="w-full bg-rescue-red text-white py-4 rounded-xl font-black text-lg hover:bg-rescue-red-dark transition-all shadow-xl hover:scale-[1.02]">
            <i class="fas fa-lock mr-2"></i>Pay $<%= total.toFixed(2) %> — Get Instant Access!
          </button>
          <p class="text-center text-xs text-gray-400 mt-2"><i class="fas fa-shield-alt text-green-500 mr-1"></i>256-bit SSL encrypted • Secure payment</p>
        </form>
      </div>
    </div>

    <!-- Order Summary -->
    <div>
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
        <h3 class="font-display font-bold text-lg mb-4">Your Order</h3>
        <div class="space-y-3 mb-5">
          <% cartItems.forEach(item => { %>
          <div class="flex items-center gap-3 py-2 border-b border-gray-50">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl flex-shrink-0 bg-gray-50">
              <%= item.subject === 'Chemistry' ? '⚗️' : item.subject === 'Biology' ? '🧬' : item.subject === 'Mathematics' ? '🔢' : '📚' %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800 truncate"><%= item.title %></p>
              <p class="text-xs text-gray-500"><%= item.level %></p>
            </div>
            <p class="font-bold text-rescue-red flex-shrink-0">$<%= item.price.toFixed(2) %></p>
          </div>
          <% }) %>
        </div>
        <div class="flex justify-between font-black text-xl border-t border-gray-100 pt-4 mb-5">
          <span>Total</span>
          <span class="text-rescue-red">$<%= total.toFixed(2) %></span>
        </div>
        <div class="bg-green-50 rounded-xl p-4 space-y-2 text-sm text-green-700">
          <div class="flex items-center gap-2"><i class="fas fa-bolt text-yellow-500"></i>Guides available instantly after payment</div>
          <div class="flex items-center gap-2"><i class="fas fa-download text-green-600"></i>Download up to 5 times per guide</div>
          <div class="flex items-center gap-2"><i class="fas fa-headset text-blue-500"></i>24/7 support at hello@rescuestudyguides.com</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function formatCard(input) {
  let v = input.value.replace(/\D/g,'').substring(0,16);
  input.value = v.replace(/(.{4})/g,'$1 ').trim();
}
</script>
