<!-- PRODUCT DETAIL PAGE -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="grid lg:grid-cols-3 gap-10">
    
    <!-- Left: Cover & Actions -->
    <div class="lg:col-span-1">
      <div class="rounded-3xl overflow-hidden shadow-xl mb-5" style="background: linear-gradient(135deg, <%= product.category_color || '#E63946' %>22, <%= product.category_color || '#E63946' %>55); min-height: 300px; display: flex; align-items: center; justify-content: center;">
        <% if (product.cover_image) { %>
          <img src="<%= product.cover_image %>" alt="<%= product.title %>" class="w-full object-cover">
        <% } else { %>
          <div class="text-center py-16">
            <div class="text-8xl mb-4"><%= product.subject === 'Chemistry' ? '⚗️' : product.subject === 'Biology' ? '🧬' : product.subject === 'Mathematics' ? '🔢' : product.subject === 'Physics' ? '⚡' : '📚' %></div>
            <p class="font-display font-black text-xl" style="color: <%= product.category_color || '#E63946' %>"><%= product.subject %></p>
          </div>
        <% } %>
      </div>

      <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-6 sticky top-24">
        <div class="text-center mb-5">
          <% if (product.is_free || product.price === 0) { %>
            <div class="font-display font-black text-4xl text-green-600">FREE</div>
            <p class="text-gray-500 text-sm mt-1">No payment required</p>
          <% } else { %>
            <div class="font-display font-black text-4xl text-rescue-red">$<%= product.price.toFixed(2) %></div>
            <% if (product.original_price && product.original_price > product.price) { %>
            <p class="text-gray-400 text-sm mt-1">
              <span class="line-through">$<%= product.original_price.toFixed(2) %></span>
              <span class="bg-rescue-red text-white text-xs font-bold px-2 py-0.5 rounded-full ml-2"><%= Math.round((1 - product.price/product.original_price) * 100) %>% OFF</span>
            </p>
            <% } %>
          <% } %>
        </div>

        <% if (owned) { %>
          <div class="bg-green-50 border border-green-200 rounded-xl p-3 text-center mb-3">
            <p class="text-green-700 font-semibold text-sm">✅ You own this guide!</p>
          </div>
          <a href="/account/downloads" class="btn-rescue w-full justify-center mb-3 block text-center">
            <i class="fas fa-download mr-2"></i>Go to My Downloads
          </a>
        <% } else if (isLoggedIn) { %>
          <% if (inCart) { %>
          <a href="/cart" class="block w-full text-center bg-green-600 text-white px-6 py-3.5 rounded-xl font-bold mb-3 hover:bg-green-700 transition-colors">
            <i class="fas fa-check mr-2"></i>In Cart — View Cart
          </a>
          <% } else { %>
          <button data-add-cart="<%= product.id %>" class="w-full bg-rescue-red text-white px-6 py-3.5 rounded-xl font-bold mb-3 hover:bg-rescue-red-dark transition-all hover:scale-[1.02] shadow-md">
            <i class="fas fa-<%= product.is_free || product.price === 0 ? 'download' : 'cart-plus' %> mr-2"></i>
            <%= product.is_free || product.price === 0 ? 'Get Free Guide' : 'Add to Cart' %>
          </button>
          <% } %>
          <button data-wishlist="<%= product.id %>" class="w-full border-2 <%= inWishlist ? 'border-rescue-red bg-red-50' : 'border-gray-200' %> text-gray-600 px-6 py-3 rounded-xl font-semibold text-sm hover:border-rescue-red transition-all">
            <i class="<%= inWishlist ? 'fas' : 'far' %> fa-heart mr-2 text-rescue-red"></i>
            <%= inWishlist ? 'In Wishlist' : 'Add to Wishlist' %>
          </button>
        <% } else { %>
          <a href="/auth/login" class="block w-full text-center bg-rescue-red text-white px-6 py-3.5 rounded-xl font-bold mb-3 hover:bg-rescue-red-dark transition-all">Sign in to Purchase</a>
          <a href="/auth/register" class="block w-full text-center border-2 border-rescue-red text-rescue-red px-6 py-3 rounded-xl font-semibold text-sm hover:bg-rescue-red hover:text-white transition-all">Join Free 🚀</a>
        <% } %>

        <div class="mt-5 pt-4 border-t border-gray-100 space-y-2.5">
          <div class="flex items-center gap-3 text-sm text-gray-600"><i class="fas fa-file-pdf text-rescue-red w-4"></i>Instant PDF Download</div>
          <div class="flex items-center gap-3 text-sm text-gray-600"><i class="fas fa-print text-rescue-red w-4"></i>Print-Ready Quality</div>
          <div class="flex items-center gap-3 text-sm text-gray-600"><i class="fas fa-mobile-alt text-rescue-red w-4"></i>Works on All Devices</div>
          <div class="flex items-center gap-3 text-sm text-gray-600"><i class="fas fa-shield-alt text-rescue-red w-4"></i>Secure & Encrypted</div>
        </div>
      </div>
    </div>

    <!-- Right: Details -->
    <div class="lg:col-span-2">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-5">
        <a href="/" class="hover:text-rescue-red">Home</a><span>/</span>
        <a href="/shop" class="hover:text-rescue-red">Shop</a><span>/</span>
        <span class="text-gray-700 font-medium truncate max-w-xs"><%= product.title %></span>
      </nav>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-xs font-bold px-3 py-1.5 rounded-full text-white" style="background: <%= product.category_color || '#E63946' %>"><%= product.category_name %></span>
        <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-gray-100 text-gray-600"><%= product.curriculum %></span>
        <span class="text-xs font-bold px-3 py-1.5 rounded-full bg-gray-100 text-gray-600"><%= product.level %></span>
      </div>

      <h1 class="font-display font-black text-3xl lg:text-4xl text-gray-900 mb-4 leading-tight"><%= product.title %></h1>

      <div class="flex flex-wrap gap-5 mb-6 text-sm text-gray-500">
        <span class="flex items-center gap-1.5"><i class="fas fa-file-alt text-rescue-red"></i><strong class="text-gray-700"><%= product.pages %></strong> pages</span>
        <span class="flex items-center gap-1.5"><i class="fas fa-download text-rescue-red"></i><strong class="text-gray-700"><%= product.downloads_count %></strong> downloads</span>
      </div>

      <p class="text-gray-600 leading-relaxed text-lg mb-8"><%= product.description %></p>

      <div class="bg-rescue-cream rounded-2xl p-6 mb-8 border border-red-100">
        <h3 class="font-display font-bold text-lg text-gray-800 mb-4">📦 What's Inside This Rescue Guide?</h3>
        <div class="grid sm:grid-cols-2 gap-3">
          <% ['Color-coded topic breakdowns','Key concepts & definitions','Worked examples & solutions','Exam tips from experienced teachers','Cheat sheets & quick references','Practice question hints'].forEach(f => { %>
          <div class="flex items-center gap-2.5">
            <div class="w-5 h-5 bg-rescue-red rounded-full flex items-center justify-center flex-shrink-0"><i class="fas fa-check text-white text-xs"></i></div>
            <span class="text-sm text-gray-700"><%= f %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div>
        <h3 class="font-display font-bold text-xl text-gray-800 mb-5">Student Reviews (<%= reviews.length %>)</h3>
        <% if (reviews.length === 0) { %>
        <div class="bg-gray-50 rounded-2xl p-6 text-center text-gray-500">
          <div class="text-4xl mb-2">💬</div>
          <p>No reviews yet — be the first!</p>
        </div>
        <% } else { %>
        <div class="space-y-4">
          <% reviews.forEach(review => { %>
          <div class="testimonial-card">
            <div class="flex items-start justify-between mb-2">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-rescue-red/10 rounded-full flex items-center justify-center font-bold text-rescue-red text-sm"><%= review.user_name.charAt(0) %></div>
                <div>
                  <p class="font-semibold text-sm text-gray-800"><%= review.user_name %></p>
                  <div class="flex text-yellow-400 text-xs"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></div>
                </div>
              </div>
              <span class="text-xs text-gray-400"><%= new Date(review.created_at).toLocaleDateString() %></span>
            </div>
            <% if (review.comment) { %><p class="text-sm text-gray-600 italic">"<%= review.comment %>"</p><% } %>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (related.length > 0) { %>
  <div class="mt-16">
    <h2 class="font-display font-black text-2xl text-gray-800 mb-6">You Might Also Like 👀</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <% related.forEach(p => { %>
      <a href="/product/<%= p.slug %>" class="product-card bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="h-32 flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, #E6394622, #E6394644);">
          <%= p.subject === 'Chemistry' ? '⚗️' : p.subject === 'Biology' ? '🧬' : p.subject === 'Mathematics' ? '🔢' : p.subject === 'Physics' ? '⚡' : '📚' %>
        </div>
        <div class="p-4">
          <p class="font-semibold text-sm text-gray-800 line-clamp-2 mb-2"><%= p.title %></p>
          <p class="font-black text-rescue-red text-lg">$<%= p.price.toFixed(2) %></p>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>
