<!-- CART PAGE -->
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="font-display font-black text-3xl text-gray-800 mb-8">🛒 Your Cart</h1>

  <% if (cartItems.length === 0) { %>
  <div class="text-center py-20 bg-white rounded-3xl shadow-sm border border-gray-100">
    <div class="text-7xl mb-4">🛒</div>
    <h3 class="font-display font-bold text-xl text-gray-700 mb-2">Your cart is empty!</h3>
    <p class="text-gray-500 mb-6">Browse our study guides and rescue your exam results</p>
    <a href="/shop" class="btn-rescue">Browse Guides</a>
  </div>
  <% } else { %>
  <div class="grid lg:grid-cols-3 gap-8">
    <!-- Cart Items -->
    <div class="lg:col-span-2 space-y-4">
      <% cartItems.forEach(item => { %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
        <div class="w-16 h-16 rounded-xl flex items-center justify-center text-3xl flex-shrink-0" style="background: linear-gradient(135deg, #E6394622, #E6394444);">
          <%= item.subject === 'Chemistry' ? '⚗️' : item.subject === 'Biology' ? '🧬' : item.subject === 'Mathematics' ? '🔢' : item.subject === 'Physics' ? '⚡' : '📚' %>
        </div>
        <div class="flex-1 min-w-0">
          <a href="/product/<%= item.slug %>" class="font-display font-bold text-gray-800 hover:text-rescue-red transition-colors line-clamp-1"><%= item.title %></a>
          <p class="text-xs text-gray-500 mt-1"><%= item.curriculum %> • <%= item.level %> • <%= item.pages %> pages</p>
          <p class="text-xs text-green-600 mt-1"><i class="fas fa-check-circle mr-1"></i>Instant PDF Download</p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="font-black text-rescue-red text-xl">$<%= item.price.toFixed(2) %></p>
          <button data-remove-cart="<%= item.id %>" class="text-gray-400 hover:text-red-500 text-xs mt-1 transition-colors">
            <i class="fas fa-trash mr-1"></i>Remove
          </button>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Order Summary -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
        <h3 class="font-display font-bold text-lg text-gray-800 mb-5">Order Summary</h3>
        <div class="space-y-3 mb-4">
          <% cartItems.forEach(item => { %>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600 truncate mr-4"><%= item.title.length > 28 ? item.title.substring(0, 28) + '…' : item.title %></span>
            <span class="font-semibold flex-shrink-0">$<%= item.price.toFixed(2) %></span>
          </div>
          <% }) %>
        </div>

        <!-- Subtotal -->
        <div class="border-t border-gray-100 pt-3 mb-3">
          <div class="flex justify-between text-sm text-gray-600 mb-1">
            <span>Subtotal</span>
            <span id="cartSubtotal">$<%= subtotal.toFixed(2) %></span>
          </div>
          <div id="discountRow" class="<%= discount > 0 ? '' : 'hidden' %> flex justify-between text-sm font-semibold">
            <span class="text-green-600">🏷️ Discount <span id="couponLabel"><%= coupon ? '(' + coupon.code + ')' : '' %></span></span>
            <span class="text-green-600" id="discountAmt">-$<%= discount.toFixed(2) %></span>
          </div>
        </div>

        <!-- Total -->
        <div class="border-t border-gray-100 pt-3 mb-5">
          <div class="flex justify-between font-black text-lg">
            <span>Total</span>
            <span class="text-rescue-red" id="cartTotal">$<%= total.toFixed(2) %></span>
          </div>
        </div>

        <!-- Coupon Code Section -->
        <div class="mb-5 bg-gray-50 rounded-xl p-4 border border-dashed border-gray-200">
          <p class="text-xs font-bold text-gray-600 mb-2 uppercase tracking-wide"><i class="fas fa-tag text-rescue-red mr-1"></i>Discount / Coupon Code</p>
          <% if (coupon) { %>
          <!-- Coupon already applied -->
          <div id="couponApplied" class="flex items-center justify-between bg-green-50 border border-green-200 rounded-lg px-3 py-2">
            <span class="text-green-700 text-sm font-bold"><%= coupon.code %> — saved $<%= discount.toFixed(2) %></span>
            <button onclick="removeCoupon()" class="text-red-400 hover:text-red-600 text-xs font-semibold ml-2">Remove</button>
          </div>
          <div id="couponInput" class="hidden">
            <div class="flex gap-2">
              <input type="text" id="couponCode" placeholder="e.g. RESCUE30"
                class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:border-rescue-red">
              <button onclick="applyCoupon()" class="bg-rescue-red text-white px-3 py-2 rounded-lg text-sm font-bold hover:opacity-90">Apply</button>
            </div>
            <p id="couponMsg" class="text-xs mt-1.5 font-medium hidden"></p>
          </div>
          <% } else { %>
          <div id="couponApplied" class="hidden flex items-center justify-between bg-green-50 border border-green-200 rounded-lg px-3 py-2">
            <span class="text-green-700 text-sm font-bold" id="appliedLabel"></span>
            <button onclick="removeCoupon()" class="text-red-400 hover:text-red-600 text-xs font-semibold ml-2">Remove</button>
          </div>
          <div id="couponInput">
            <div class="flex gap-2">
              <input type="text" id="couponCode" placeholder="e.g. RESCUE30"
                class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:border-rescue-red">
              <button onclick="applyCoupon()" class="bg-rescue-red text-white px-3 py-2 rounded-lg text-sm font-bold hover:opacity-90">Apply</button>
            </div>
            <p id="couponMsg" class="text-xs mt-1.5 font-medium hidden"></p>
          </div>
          <% } %>
        </div>

        <a href="/cart/checkout" class="block w-full text-center bg-rescue-red text-white py-3.5 rounded-xl font-bold hover:bg-rescue-red-dark transition-all hover:scale-[1.02] shadow-md mb-3">
          <i class="fas fa-lock mr-2"></i>Secure Checkout
        </a>
        <a href="/shop" class="block w-full text-center text-gray-500 text-sm hover:text-rescue-red transition-colors">
          <i class="fas fa-arrow-left mr-1"></i>Continue Shopping
        </a>

        <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-center gap-3 text-xs text-gray-400">
          <i class="fas fa-lock text-green-500"></i> Secure & Encrypted Checkout
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<script>
function applyCoupon() {
  var code = (document.getElementById('couponCode').value || '').trim().toUpperCase();
  var msg  = document.getElementById('couponMsg');
  if (!code) { showMsg('Enter a coupon code.', 'red'); return; }

  fetch('/cart/coupon/apply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    body: JSON.stringify({ code: code })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      // Update totals
      document.getElementById('discountRow').classList.remove('hidden');
      document.getElementById('couponLabel').textContent = '(' + code + ')';
      document.getElementById('discountAmt').textContent = '-$' + data.discount;
      document.getElementById('cartTotal').textContent   = '$' + data.newTotal;
      // Show applied state
      document.getElementById('couponInput').classList.add('hidden');
      var appl = document.getElementById('couponApplied');
      appl.classList.remove('hidden');
      appl.querySelector('#appliedLabel') && (appl.querySelector('#appliedLabel').textContent = code + ' — saved $' + data.discount);
      appl.querySelector('span').textContent = code + ' — saved $' + data.discount;
    } else {
      showMsg(data.message, 'red');
    }
  })
  .catch(() => showMsg('Network error — try again.', 'red'));
}

function removeCoupon() {
  fetch('/cart/coupon/remove', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(() => location.reload());
}

function showMsg(text, color) {
  var el = document.getElementById('couponMsg');
  el.textContent = text;
  el.style.color = color === 'red' ? '#dc2626' : '#16a34a';
  el.classList.remove('hidden');
}
</script>
