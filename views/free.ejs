<!-- FREE GUIDES PAGE -->

<!-- Hero -->
<div class="page-hero" style="background: linear-gradient(135deg, #1E2A3A 0%, #16213E 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-14 text-center">
    <span class="inline-block bg-green-500 text-white text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">100% Free — No Credit Card</span>
    <h1 class="font-display font-black text-4xl lg:text-5xl text-white mb-4">🎁 Free Study Guides</h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">Premium-quality rescue guides — completely free. Download instantly, no sign-up drama. Pick your subject below.</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

  <!-- Subject Filter Tabs -->
  <div class="mb-10">
    <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Filter by Subject</h2>
    <div class="flex flex-wrap gap-2">
      <a href="/free"
        class="px-5 py-2 rounded-full text-sm font-bold transition-all border-2
        <%= currentSubject === 'all' ? 'bg-rescue-red text-white border-rescue-red shadow-md' : 'border-gray-200 text-gray-600 hover:border-rescue-red hover:text-rescue-red bg-white' %>">
        📚 All Subjects
      </a>
      <% subjects.forEach(sub => { %>
      <a href="/free?subject=<%= encodeURIComponent(sub) %>"
        class="px-5 py-2 rounded-full text-sm font-bold transition-all border-2
        <%= currentSubject && currentSubject.toLowerCase() === sub.toLowerCase() ? 'bg-rescue-red text-white border-rescue-red shadow-md' : 'border-gray-200 text-gray-600 hover:border-rescue-red hover:text-rescue-red bg-white' %>">
        <%= sub === 'Chemistry' ? '⚗️' : sub === 'Biology' ? '🧬' : sub === 'Mathematics' ? '🔢' : sub === 'Physics' ? '⚡' : sub === 'English' ? '📖' : '📚' %>
        <%= sub %>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- Results Count -->
  <div class="flex items-center justify-between mb-6">
    <p class="text-gray-600 text-sm">
      <strong><%= freeGuides.length %></strong> free guide<%= freeGuides.length !== 1 ? 's' : '' %> available
      <% if (currentSubject && currentSubject !== 'all') { %> in <strong><%= currentSubject %></strong><% } %>
    </p>
    <a href="/shop" class="text-sm text-rescue-red font-semibold hover:underline">
      <i class="fas fa-store mr-1"></i>Browse Premium Guides →
    </a>
  </div>

  <!-- Guide Cards -->
  <% if (freeGuides.length === 0) { %>
  <div class="text-center py-24 bg-white rounded-3xl border border-dashed border-gray-200">
    <div class="text-7xl mb-4">🔍</div>
    <h3 class="font-display font-bold text-xl text-gray-700 mb-2">No free guides yet for this subject</h3>
    <p class="text-gray-500 mb-6">Check back soon — Mr. Hisham adds new free guides regularly!</p>
    <a href="/free" class="btn-rescue">View All Free Guides</a>
  </div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% freeGuides.forEach(product => { %>
    <a href="/product/<%= product.slug %>" class="group product-card bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-200 block">
      <!-- Cover -->
      <div class="relative h-44 overflow-hidden" style="background: linear-gradient(135deg, <%= product.category_color || '#16a34a' %>22, <%= product.category_color || '#16a34a' %>55);">
        <% if (product.cover_image) { %>
          <img src="<%= product.cover_image %>" alt="<%= product.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
        <% } else { %>
          <div class="w-full h-full flex flex-col items-center justify-center">
            <div class="text-5xl mb-2">
              <%= product.subject === 'Mathematics' ? '🔢' : product.subject === 'Biology' ? '🧬' : product.subject === 'Chemistry' ? '⚗️' : product.subject === 'Physics' ? '⚡' : product.subject === 'English' ? '📖' : '📚' %>
            </div>
            <p class="font-bold text-xs" style="color: <%= product.category_color || '#16a34a' %>"><%= product.subject %></p>
          </div>
        <% } %>
        <!-- FREE badge -->
        <div class="absolute top-3 left-3">
          <span class="bg-green-500 text-white text-xs font-black px-3 py-1 rounded-full shadow-md">🎁 FREE</span>
        </div>
      </div>

      <div class="p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-bold px-2 py-0.5 rounded-full text-white" style="background: <%= product.category_color || '#16a34a' %>"><%= product.subject %></span>
          <span class="text-xs text-gray-400"><%= product.curriculum || 'General' %></span>
        </div>
        <h3 class="font-display font-bold text-gray-800 text-sm mb-2 line-clamp-2 leading-tight group-hover:text-rescue-red transition-colors">
          <%= product.title %>
        </h3>
        <div class="flex items-center gap-3 text-xs text-gray-400 mb-3">
          <span><i class="fas fa-file-alt mr-1"></i><%= product.pages %> pages</span>
          <span><i class="fas fa-download mr-1"></i><%= product.downloads_count %> downloads</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-black text-green-600 text-xl">FREE</span>
          <div class="flex gap-1.5">
            <a href="/product/<%= product.slug %>" class="bg-gray-100 text-gray-600 px-2.5 py-1.5 rounded-lg text-xs font-bold hover:bg-gray-200 transition-all">
              <i class="fas fa-eye mr-1"></i>View
            </a>
            <span class="bg-green-500 text-white px-2.5 py-1.5 rounded-lg text-xs font-bold group-hover:bg-green-600 transition-colors">
              <i class="fas fa-download mr-1"></i>Get
            </span>
          </div>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>

  <!-- Upsell Banner -->
  <div class="mt-16 bg-gradient-to-r from-rescue-dark to-gray-900 rounded-3xl p-8 text-center text-white">
    <h2 class="font-display font-black text-2xl mb-3">Want the Full Rescue Experience? 🚀</h2>
    <p class="text-gray-300 mb-6 max-w-xl mx-auto">Unlock 50+ premium study guides covering every topic in depth — color-coded, exam-ready, and built to help you ace it.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/shop" class="bg-rescue-red text-white px-6 py-3 rounded-xl font-bold hover:opacity-90 transition-opacity">
        <i class="fas fa-store mr-2"></i>Browse Premium Guides
      </a>
      <a href="/auth/register" class="border-2 border-white/30 text-white px-6 py-3 rounded-xl font-semibold hover:bg-white/10 transition-colors">
        <i class="fas fa-user-plus mr-2"></i>Join Free Today
      </a>
    </div>
  </div>
</div>
